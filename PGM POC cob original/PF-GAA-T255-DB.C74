196500/
196600*----------------------------------------------------------------*
196700*        ROTINA  DE  TRATAMENTO  DAS  TRANSACOES  DO  PROGRAMA   *
196800*----------------------------------------------------------------*
196900
197000 020-E-PROCESSA.
197100
197200
198100      MOVE  SPACES TO C-MAPA.
198200      RECEIVE COMS-IN MESSAGE INTO C-MAPA.
198300      IF STATUSVALUE OF COMS-IN = 99
198400                 GO TO 020-S-PROCESSA.
198500      IF FUNCTIONSTATUS OF COMS-IN < 0
198600                 GO TO 020-S-PROCESSA.
198700      IF STATUSVALUE OF COMS-IN  NOT = 0  AND
198800         STATUSVALUE OF COMS-IN  NOT = 80 AND
198900         STATUSVALUE OF COMS-IN  NOT = 89 AND
199000         STATUSVALUE OF COMS-IN  NOT = 90 AND
199100         STATUSVALUE OF COMS-IN  NOT = 91 AND
199200         STATUSVALUE OF COMS-IN  NOT = 92 AND
199300         STATUSVALUE OF COMS-IN  NOT = 93 AND
199400         STATUSVALUE OF COMS-IN  NOT = 94 AND
199500         STATUSVALUE OF COMS-IN  NOT = 97
199600       DISPLAY "PC/GAA/T255/DB - INV.KEY REMOTE"
199700       DIVIDE  0               INTO    WS-CONTIME.
199800      MOVE H-MAPA-E   TO C-HEADER.
200000
200100
200200     IF      MAPA-E-S                EQUAL   "ENDEND"
200300             PERFORM 320-E-FINAL     THRU    320-S-FINAL
200400             STOP    RUN.
200500
200600
200700     IF      WS-AUXILIA              EQUAL   1
200800             MOVE    0               TO      WS-AUXILIA
200900             GO      020-S-PROCESSA
201000     ELSE
201100             MOVE    0               TO      WS-CONTIME.
201200
201300     MOVE    TELA                    TO      SALVA-TELA.
201400     MOVE    USUARIO                 TO      WS-USU.
201500
