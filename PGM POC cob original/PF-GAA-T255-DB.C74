547312             WAIT    3
547314             GO      TO                      800-10-TAXAS-PP
547316         ELSE
547318         IF  DMSTATUS(NOTFOUND)
547320***             IF      AX-TAX-SITU     =       2
547322***                     MOVE    1       TO      AX-TAX-SITU
547324***                     SET     TAXPLACASS1     TO      ENDING
547326***                    GO              TO      800-10-TAXAS-PP
547328***             ELSE
547330                     FREE    TAXASDS
547332                     GO              TO      800-S-TAXAS-PP
547334         ELSE
547336             DISPLAY "PC/GAA/T255/DB : LOCK ERROR TAX PP"
547338             PERFORM 220-E-ERRODB    THRU    220-S-ERRODB
547340             CALL    SYSTEM          DMTERMINATE.
547342
547344
547346      CREATE VALIDADOSDS
547348        ON   EXCEPTION
547350             DISPLAY "PC/GAA/T255/DB : CREATE ERROR VALIDADO PP"
547352             PERFORM 220-E-ERRODB    THRU    220-S-ERRODB
547354             CALL    SYSTEM          DMTERMINATE.
547356
547358     MOVE    TAXASDS                 TO      TAV-TAXASDS.
547360     MOVE    3                       TO      TAV-SITUACAO.
547362     MOVE    "AUMI"                  TO      TAV-TRANSACAO-F.
547364     MOVE    USUARIO                 TO      TAV-USUARIO-F.
547366     ACCEPT  TAV-DT-VALID-F          FROM    DATE YYYYMMDD.
547368     ACCEPT  TAV-HR-VALID-F          FROM    TIME.
547370
547372
547374     BEGIN-TRANSACTION            NO-AUDIT   TAXASRDSDS
547376       ON    EXCEPTION
547378             DISPLAY "PC/GAA/T255/DB : BEGIN-TR ERROR TAXAS PP"
547380             PERFORM 220-E-ERRODB    THRU    220-S-ERRODB
547382             CALL    SYSTEM          DMTERMINATE.
547384
547386
547388     STORE   VALIDADOSDS
547390       ON    EXCEPTION
547392             DISPLAY "PC/GAA/T255/DB : STORE ERROR VALIDADO PP"
547394             PERFORM 220-E-ERRODB    THRU    220-S-ERRODB
547396             CALL    SYSTEM          DMTERMINATE.
547398
547400
547402     DELETE  TAXASDS
547404       ON    EXCEPTION
547406             DISPLAY "PC/GAA/T255/DB : DELETE ERROR TAXASDS PP"
547408             PERFORM 220-E-ERRODB    THRU    220-S-ERRODB
547410             CALL    SYSTEM          DMTERMINATE.
547412
547414
547416     END-TRANSACTION              NO-AUDIT   TAXASRDSDS
547418       ON    EXCEPTION
547420             DISPLAY "PC/GAA/T255/DB : END-TRANSAC ERROR TAXAS PP"
547422             PERFORM 220-E-ERRODB    THRU    220-S-ERRODB
547424             CALL    SYSTEM          DMTERMINATE.
547426
547428
547430     FREE    TAXASDS.
547432
547434
547436 800-S-TAXAS-PP.
547438     EXIT.
