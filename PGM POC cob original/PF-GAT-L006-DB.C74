022800*    ROTINA PRINCIPAL DO PROGRAMA                                *
022900*----------------------------------------------------------------*
023000*
023100 000-E-PROCEDURE.
023200*
023300     IF      CH-BCO                  =       "S"
023400             GO                      TO      000-05.
023500
023600     OPEN    INQUIRY DB01
023700       ON    EXCEPTION
023800             DISPLAY "PC/GAT/L006/DB - ERRO ABERTURA DBBLOQUEIO"
023900             CALL    SYSTEM  DMTERMINATE.
024000
024100     MOVE    "S"                     TO      CH-BCO.
024200
024300 000-05.
024400
024500     MOVE    ZEROS                   TO      AX-RET-FLAG
024600                                             AX-RET-MUNIC.
024700     MOVE    SPACES                  TO      AX-RET-PLAMERC
024800                                             AX-RET-CHASS
024900                                             AX-RET-BLOQUEIO
025000                                             CH-PESQUISA.
025100     MOVE    " "                     TO      CH-NOTFOUND.
025200     MOVE    0                       TO      AX-BLOQ-02-23.
025300     MOVE    0                       TO      AX-BLQ-SINISTRO.
025400
025500
025600     IF      AX-GAT-CHASS        NOT =       LOW-VALUES AND
025700                                             SPACES AND ZEROS
025800             MOVE    AX-GAT-CHASS    TO      CH-CHASSIS
025900             SET     BLOCHASSE       TO      BEGINNING
026000             SET     REJCHASSISS     TO      BEGINNING
026100     ELSE
026200             MOVE    AX-GAT-PLAMERC  TO      CH-PLAMERC
026300
026400             PERFORM 100-E-VER-PLACA THRU    100-S-VER-PLACA
026500
026600             SET     REJPLAMSS2      TO      BEGINNING
026700       IF    AX-GAT-MUNIC            >       0
026800             MOVE    "PLCMN"         TO      CH-PESQUISA
026900             MOVE    AX-GAT-MUNIC    TO      CH-MUNICIPIO
027000             SET     BLOPLAMSE1      TO      BEGINNING
027100       ELSE
027200             MOVE    "PLACA"         TO      CH-PESQUISA
027300             MOVE    0               TO      CH-MUNICIPIO
027400             SET     BLOPLAMSE2      TO      BEGINNING.
027500
027600
027700
027800     MOVE    1                       TO      IA1.
027900
