057500                                             AX-RET-BLOQ(4) OR
057600                                             AX-RET-BLOQ(5) OR
057700                                             AX-RET-BLOQ(6)
057800             MOVE    BLO-TIP-BLOQ    TO      AX-BLOQ-02-23
057900             GO                      TO      015-S-FIND-BLOQ-AUX
058000       ELSE
058100             NEXT    SENTENCE
058200     ELSE
058300             NEXT    SENTENCE.
058400
058500
058600     IF      BLO-TIP-BLOQ            =       41  OR  40  OR  14
058700       IF    (AX-RET-BLOQ(1)         =       41 OR 40 OR 14) OR
058800             (AX-RET-BLOQ(2)         =       41 OR 40 OR 14) OR
058900             (AX-RET-BLOQ(3)         =       41 OR 40 OR 14) OR
059000             (AX-RET-BLOQ(4)         =       41 OR 40 OR 14) OR
059100             (AX-RET-BLOQ(5)         =       41 OR 40 OR 14) OR
