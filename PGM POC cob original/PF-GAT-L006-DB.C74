078500*----------------------------------------------------------------*
078600*        SELECIONAR  AS  RESTRICOES  ATIVAS  DE  RENAJUD         *
078700*----------------------------------------------------------------*
078800*
078900 050-E-RESTR-REJ.
079000
079100
079200
079300     IF      REJ-DT-RETIRADA (IX1)   >       0   OR
079400             REJ-TIPO-RESTR  (IX1)   =       0
079500             GO                      TO      050-S-RESTR-REJ.
079600
079700
079800
079900     IF      REJ-TIPO-RESTR (IX1)    =       1
080000             MOVE    51              TO      AX-BLOQ-RENAJUD
080100     ELSE
080200     IF      REJ-TIPO-RESTR (IX1)    =       2
080300             MOVE    52              TO      AX-BLOQ-RENAJUD
080400     ELSE
080500     IF      REJ-TIPO-RESTR (IX1)    =       3
080600             MOVE    53              TO      AX-BLOQ-RENAJUD
080700     ELSE
080800     IF      REJ-TIPO-RESTR (IX1)    =       4
080900             MOVE    54              TO      AX-BLOQ-RENAJUD
081000     ELSE
081100             COMPUTE AX-BLOQ-RENAJUD =  REJ-TIPO-RESTR(IX1) + 50.
081200
081300
081400
081500     IF      AX-BLOQ-RENAJUD         =       AX-RET-BLOQ(1)  OR
081600                                             AX-RET-BLOQ(2)  OR
081700                                             AX-RET-BLOQ(3)  OR
081800                                             AX-RET-BLOQ(4)  OR
081900                                             AX-RET-BLOQ(5)  OR
082000                                             AX-RET-BLOQ(6)
082100             GO                      TO      050-S-RESTR-REJ.
082200
082300
082400
082500     IF      AX-RET-BLOQ(1)          =       0
082600             MOVE    REJ-CHASSI      TO      AX-RET-CHASS
082700             MOVE    REJ-MUNICIPIO   TO      AX-RET-MUNIC
082800             MOVE    REJ-PLACA-MERC  TO      AX-RET-PLAMERC
082900             MOVE    AX-BLOQ-RENAJUD TO      AX-RET-BLOQ(1)
083000     ELSE
083100     IF      AX-RET-BLOQ(2)          =       0
083200             MOVE    AX-BLOQ-RENAJUD TO      AX-RET-BLOQ(2)
083300     ELSE
083400     IF      AX-RET-BLOQ(3)          =       0
083500             MOVE    AX-BLOQ-RENAJUD TO      AX-RET-BLOQ(3)
083600     ELSE
083700     IF      AX-RET-BLOQ(4)          =       0
083800             MOVE    AX-BLOQ-RENAJUD TO      AX-RET-BLOQ(4)
083900     ELSE
084000     IF      AX-RET-BLOQ(5)          =       0
084100             MOVE    AX-BLOQ-RENAJUD TO      AX-RET-BLOQ(5)
084200     ELSE
084300             MOVE    "S"             TO      CH-NOTFOUND
084400       IF    AX-RET-BLOQ(6)          =       17  OR  23  OR  02
084500         IF  AX-RET-BLOQ(5)          =       17  OR  23  OR  02
084600             MOVE    AX-RET-BLOQ(5)  TO      AX-RET-BLOQ(4)
084700             MOVE    AX-RET-BLOQ(6)  TO      AX-RET-BLOQ(5)
084800             MOVE    AX-BLOQ-RENAJUD TO      AX-RET-BLOQ(6)
084900         ELSE
085000             MOVE    AX-RET-BLOQ(6)  TO      AX-RET-BLOQ(5)
085100             MOVE    AX-BLOQ-RENAJUD TO      AX-RET-BLOQ(6)
085200       ELSE
085300             MOVE    AX-BLOQ-RENAJUD TO      AX-RET-BLOQ(6).
085400
085500
085600
085700
085800
085900 050-S-RESTR-REJ.
086000     EXIT.
086100
