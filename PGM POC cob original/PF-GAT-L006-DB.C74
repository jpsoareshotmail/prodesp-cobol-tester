092800/----------------------------------------------------------------*
092900*            VERIFICAR PLACA LETRA / NUMERO                      *
093000*----------------------------------------------------------------*
093100
093200 100-E-VER-PLACA.
093300
093400
093500     MOVE    SPACES                  TO      CH-PLA-AUX.
093600
093700     IF     (AX-GAT-PLAMERC-ALF      NOT     NUMERIC)    AND
093800            (AX-GAT-PLAMERC-ALF      NOT     ALPHABETIC)
093900             GO                      TO      100-S-VER-PLACA
094000     ELSE
094100     IF      AX-GAT-PLAMERC-ALF      NOT     NUMERIC
094200        IF   AX-GAT-PLAMERC-ALF      >       "J"
094300             GO                      TO      100-S-VER-PLACA
094400        ELSE
094500             GO                      TO      100-20-PESQ-NUMERO
094600     ELSE
094700             NEXT    SENTENCE.
094800
094900
095000 100-10-PESQ-LETRA.
095100
095200     SET     IN1                     TO      1.
095300
095400     SEARCH  TBA-LET-NUM
095500         AT  END
095600             MOVE    SPACES          TO      CH-PLA-AUX
095700       WHEN  TBA-NUM (IN1)           =       AX-GAT-PLAMERC-ALF
095800             MOVE    AX-GAT-PLAMERC  TO      CH-PLA-AUX
095900             MOVE    TBA-LET (IN1)   TO      CH-PLA-AUX-ALF
096000
096100     GO                              TO      100-S-VER-PLACA.
096200
096300 100-20-PESQ-NUMERO.
096400
096500     SET     IN1                     TO      1.
096600
096700     SEARCH  TBA-LET-NUM
096800         AT  END
096900             MOVE    SPACES          TO      CH-PLA-AUX
097000       WHEN  TBA-LET (IN1)           =       AX-GAT-PLAMERC-ALF
097100             MOVE    AX-GAT-PLAMERC  TO      CH-PLA-AUX
097200             MOVE    TBA-NUM (IN1)   TO      CH-PLA-AUX-ALF.
097300
097400
097500 100-S-VER-PLACA.
097600     EXIT.
