013400
013500/
013600 PROCEDURE   DIVISION                USING   AX-GEV-ENVL006
013700                                             AX-GEV-RETL006.
013800
013900*----------------------------------------------------------------*
014000*    ROTINA PRINCIPAL DO PROGRAMA                                *
014100*----------------------------------------------------------------*
014200*
014300 000-E-PROCEDURE.
014400*
014500     IF      CH-BCO                  =       "S"
014600             GO                      TO      000-05.
014700
014800     OPEN    INQUIRY DB01
014900       ON    EXCEPTION
015000             DISPLAY "PC/GEV/L006/DB - ERRO ABERTURA DBBLOQUEIO"
015100             CALL    SYSTEM  DMTERMINATE.
015200
015300     MOVE    "S"                     TO      CH-BCO.
015400
015500 000-05.
015600
015700     MOVE    ZEROS                   TO      AX-RCV-FLAG
015800                                             AX-RCV-MUNIC.
015900     MOVE    SPACES                  TO      AX-RCV-PLAMERC
016000                                             AX-RCV-CHASS.
016100     MOVE    LOW-VALUES              TO      AX-RCV-INFORMACOES.
016200
016300     MOVE    0                       TO      CH-NOTFOUND.
016400     MOVE    SPACES                  TO      CH-PESQUISA.
016500
016600     IF      AX-GEV-PLAMERC          NOT =   LOW-VALUES AND
016700                                             SPACES AND ZEROS
016800             MOVE    AX-GEV-PLAMERC  TO      CH-PLAMERC
016900             MOVE    "PLACA"         TO      CH-PESQUISA
017000     ELSE
017100             MOVE    AX-GEV-CHASS    TO      CH-CHASSIS.
017200
017300
017400
017500
017600     PERFORM 010-E-FIND-COMUNIC      THRU    010-S-FIND-COMUNIC.
017700
017800
017900
018000 000-S-EXIT.
018100     EXIT PROGRAM.
018200/----------------------------------------------------------------*
018300*    P E S Q U I S A   - COMVENDS                                *
018400*----------------------------------------------------------------*
018500*
018600 010-E-FIND-COMUNIC.
018700*
018800     IF      CH-PESQUISA             =       "PLACA"
018900             PERFORM 030-E-FIND-PLACA THRU   030-S-FIND-PLACA
019000     ELSE
019100             PERFORM 020-E-FIND-CHASS THRU   020-S-FIND-CHASS.
019200*
019300     IF      CH-NOTFOUND              =      1
019400             MOVE    0                TO     AX-RCV-FLAG
019500             GO                       TO     010-S-FIND-COMUNIC
019600     ELSE
019700     IF      CVV-DT-DOCTS             >      0
019800             MOVE    1                TO     AX-RCV-FLAG
019900     ELSE
020000             MOVE    0                TO     AX-RCV-FLAG
020100             GO                       TO     010-S-FIND-COMUNIC.
020200
020300
020400     MOVE    CVV-PLACA-MERC          TO      AX-RCV-PLAMERC.
020500     MOVE    CVV-CHASSI              TO      AX-RCV-CHASS.
020600     MOVE    CVV-MUNICIPIO           TO      AX-RCV-MUNIC.
020700     MOVE    CVV-DT-VENDA            TO      AX-RCV-DT-VENDA.
020800     MOVE    CVV-DOCTO-CV            TO      AX-RCV-ID-CONTR.
020900     MOVE    CVV-CPF-CGC-CV          TO      AX-RCV-CPFCGC  .
021000     MOVE    CVV-DT-NFISCAL          TO      AX-RCV-DT-NFISC.
021100     MOVE    CVV-FINANC              TO      AX-RCV-FINANC  .
021200     MOVE    CVV-CNPJ-SEG            TO      AX-RCV-CNPJ-SEG.
021300
021400
021500
021600
021700 010-S-FIND-COMUNIC.
021800     EXIT.
021900
022000/----------------------------------------------------------------*
022100*                PESQUISA POR CHASSI                             *
022200*----------------------------------------------------------------*
022300*
022400 020-E-FIND-CHASS.
022500*
022600     FIND    CVVCHASSISE             AT
022700             CVV-CHASSI              =       CH-CHASSIS
022800       ON    EXCEPTION
022900        IF   DMSTATUS(NOTFOUND)
023000             MOVE    1               TO      CH-NOTFOUND
023100             GO                      TO      020-S-FIND-CHASS
023200        ELSE
023300             DISPLAY "PC/GEV/L006/DB - ERRO FIND CVVCHASSISE"
023400             CALL                    SYSTEM  DMTERMINATE.
023500*
023600 020-S-FIND-CHASS.
023700     EXIT.
023800
023900/----------------------------------------------------------------*
024000*                PESQUISA POR PLACA                              *
024100*----------------------------------------------------------------*
024200*
024300 030-E-FIND-PLACA.
024400*
024500     FIND    CVVPLAMSE               AT
024600             CVV-PLACA-MERC          =       CH-PLAMERC
024700       ON    EXCEPTION
024800        IF   DMSTATUS(NOTFOUND)
024900             MOVE    1               TO      CH-NOTFOUND
025000             GO                      TO      030-S-FIND-PLACA
025100        ELSE
025200             DISPLAY "PC/GEV/L006/DB - ERRO FIND CVVPLAMSE"
025300             CALL                    SYSTEM  DMTERMINATE.
025400*
025500 030-S-FIND-PLACA.
025600     EXIT.
