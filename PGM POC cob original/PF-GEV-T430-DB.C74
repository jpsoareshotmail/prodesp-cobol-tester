026800*----------------------------------------------------------------*
026900*
027000 COMMUNICATION       SECTION.
027100*-----------------------------
027200*
027300 INPUT HEADER COMS-IN;
027400       PROGRAMDESG            IS   COMS-IN-PROGRAM;
027500       FUNCTIONSTATUS         IS   COMS-IN-FUNCTION-STATUS;
027600       FUNCTIONINDEX          IS   COMS-IN-FUNCTION-INDEX;
027700       USERCODE               IS   COMS-IN-USERCODE;
027800       SECURITYDESG           IS   COMS-IN-SECURITY-DESG;
027900       TRANSPARENT            IS   COMS-IN-TRANSPARENT;
028000       VTFLAG                 IS   COMS-IN-VT-FLAG;
028100       TIMESTAMP              IS   COMS-IN-TIMESTAMP;
028200       STATION                IS   COMS-IN-STATION;
028300       TEXTLENGTH             IS   COMS-IN-TEXT-LENGTH;
028400       STATUSVALUE            IS   COMS-IN-STATUS;
028500       MESSAGECOUNT           IS   COMS-IN-MSG-COUNT;
028600       RESTART                IS   COMS-IN-RST-LOC;
028700       AGENDA                 IS   COMS-IN-AGENDA;
028800       SDFINFO                IS   COMS-IN-INFO.
028900*
029000 OUTPUT HEADER COMS-OUT;
029100       DESTCOUNT              IS   COMS-OUT-COUNT;
029200       TEXTLENGTH             IS   COMS-OUT-TEXT-LENGTH;
029300       STATUSVALUE            IS   COMS-OUT-STATUS;
029400       TRANSPARENT            IS   COMS-OUT-TRANPARENT;
029500       VTFLAG                 IS   COMS-OUT-VT-FLAG;
029600       CONFIRMFLAG            IS   COMS-OUT-CONFIRM-FLAG;
029700       CONFIRMKEY             IS   COMS-OUT-CONFIRMKEY;
029800       DESTINATIONDESG        IS   COMS-OUT-DESTINATION;
029900       NEXTINPUTAGENDA        IS   COMS-OUT-NEXT-INPUT-AG;
030000       CASUALOUTPUT           IS   COMS-OUT-CASUAL-OUTPUT;
030100       SETNEXTINPUTAGENDA     IS   COMS-OUT-SET-NEXT-AG;
030200       RETAINTRANSACTIONMODE  IS   COMS-OUT-RETAIN-TRANMODE;
030300       AGENDA                 IS   COMS-OUT-AGENDA;
030400       SDFINFO                IS   COMS-OUT-INFO.
030500*
030600******************************************************************
030700/
030800 PROCEDURE   DIVISION.
030900**********************
031000
031100******************************************************************
031200*            MODULO      MONITOR     DO      PROGRAMA            *
031300******************************************************************
031400*
031500 000-E-MONITOR.
031600
031700
031800
031900     IF      ATTRIBUTE   RESTARTED   OF      MYSELF
032000                                     EQUAL   VALUE   TRUE
032100             DISPLAY "PC/GEV/T430/DB ====> FIM NORMAL"
032200             GO                      TO      000-S-MONITOR.
032300
032400
032500     PERFORM 010-E-INICIO            THRU    010-S-INICIO.
032600
032700     PERFORM 020-E-PROCESSA          THRU    020-S-PROCESSA
032800             UNTIL   COMS-IN-STATUS  =       99.
032900
033000     PERFORM 180-E-FINAL             THRU    180-S-FINAL.
033100
033200
033300
033400 000-S-MONITOR.
033500     STOP    RUN.
033600
033700/
033800******************************************************************
033900*            MODULO      INICIAL      DO      PROGRAMA           *
034000******************************************************************
034100*
034200 010-E-INICIO.
034300
034400
034500
034600     MOVE    ATTRIBUTE NAME OF ATTRIBUTE EXCEPTIONTASK
034700                            OF ATTRIBUTE EXCEPTIONTASK OF MYSELF
034800                            TO LINKTOCOMS.
034900
035000     CHANGE  ATTRIBUTE TITLE OF "DCILIBRARY" TO LINKTOCOMS.
035100
035200     ENABLE  INPUT COMS-IN KEY "ONLINE".
035300
035400     ENABLE  INPUT COMS-IN         KEY     "ONLINE"
035500
035600     CALL    "GET_DESIGNATOR_USING_NAME  IN  DCILIBRARY"
035700                                     USING   AX-AGENDA-NAME,
035800                                     VALUE   AGENDA,
035900                                             AX-AGENDA-DESG
036000                                     GIVING  AX-CALL-ERROR.
036100
036200
036300
036400     OPEN    UPDATE      DB01
036500       ON    EXCEPTION
036600             DISPLAY "PC/GEV/T430/DB : OPEN ERROR DBDETRAN"
036700             PERFORM 170-E-ERRODB    THRU    170-S-ERRODB
036800             CALL    SYSTEM          DMTERMINATE.
036900
037000
037100     OPEN    INQUIRY     DB02
037200       ON    EXCEPTION
037300             DISPLAY "PC/GEV/T430/DB : OPEN ERROR DBGEVER"
037400             PERFORM 170-E-ERRODB    THRU    170-S-ERRODB
037500             CALL    SYSTEM          DMTERMINATE.
037600
037700
037800
037900 010-S-INICIO.
038000     EXIT.
038100
038200/
038300******************************************************************
038400*            MODULO    DE    TRATAMENTO    DE    TRANSACOES      *
038500******************************************************************
038600*
038700 020-E-PROCESSA.
038800
038900
039000
039100     MOVE    SPACES                  TO      AREA-IN
039200                                             AREA-OUT.
039300
039400     RECEIVE COMS-IN MESSAGE         INTO    AREA-IN.
039500
039600     IF      COMS-IN-STATUS          =       00 OR 92 OR 93 OR
039700                                             97 OR 89
039800             NEXT    SENTENCE
039900     ELSE
040000     IF      COMS-IN-STATUS          =       99
040100             GO                      TO      020-S-PROCESSA
040200     ELSE
040300             PERFORM 160-E-ERROCOMS  THRU    160-S-ERROCOMS
040400             GO                      TO      020-S-PROCESSA.
040500
040600
040700     ACCEPT  AX-DATE-4AMMDD          FROM    DATE  YYYYMMDD.
040800     ACCEPT  AX-TIME                 FROM    TIME.
040900
041000
041100      IF     IN-CODE                 =       "V430"
041200             PERFORM 030-E-V430      THRU    030-S-V430
041300      ELSE
041400             MOVE    968             TO      OUT-COD-RET
041500             MOVE    IN-CPF-CGC-X    TO      OUT-CPF-CGC-X
041600             MOVE    105             TO      AX-LENGTH.
041700
041800
041900
042000 020-10-MSG.
042100
042200
042300     PERFORM 150-E-MSGOUT            THRU    150-S-MSGOUT.
042400
042500
042600     FREE    NOVAPLACDS.
042700
042800
042900
043000 020-S-PROCESSA.
043100     EXIT.
043200
043300/
043400******************************************************************
043500*            TRATA TRANSACAO V430                                *
043600******************************************************************
043700*
043800 030-E-V430.
043900
044000
044100
044200     MOVE    ZEROS                   TO      OUT-COD-RET
044300                                             OUT-SELECIONADA
044400                                             AX-SELECAO.
044500     MOVE    SPACES                  TO      CH-ATUALIZ
044505                                             AX-ALTEROU
044510                                             AX-PLACA-PERSON.
044600     MOVE    "N"                     TO      CH-CHASSI
044650                                             OUT-PAGAMENTO.
044700
044705** VERIFICA DATA MERCOSUL
044710     MOVE    ZEROS                  TO      AX-CRV-MERC.
044715     PERFORM 190-E-PRODCRV-MERC     THRU    190-S-PRODCRV-MERC.
044720
044800     PERFORM 040-E-CONSISTE          THRU    040-S-CONSISTE.
044900
045000      IF      OUT-COD-RET             >      0  OR
045010              AX-PLACA-PERSON         =      "X"
045100              GO                      TO     030-10-ENVIA
045200      ELSE
045300              NEXT    SENTENCE.
045400
045500*  -->  Chassi encontrado
045600     IF      CH-CHASSI               =       "S"
045700             MOVE    "G"             TO      CH-ATUALIZ
045800             GO                      TO      030-10-ENVIA
045900     ELSE
046000             NEXT    SENTENCE.
046100
046200*  --->  Aloca e atualiza a placa no Dataset
046300     PERFORM 100-E-PLACA-SORT        THRU    100-S-PLACA-SORT.
046600
046700
046800 030-10-ENVIA.
046900
047000     PERFORM 140-E-ENVIA-OUT         THRU    140-S-ENVIA-OUT.
047100
047200
047300
047400 030-S-V430.
047500     EXIT.
047600
047700/
047800******************************************************************
047900*            CONSISTE STRING DE ENTRADA                          *
048000******************************************************************
048100*
048200 040-E-CONSISTE.
048300
048400
048500
048600     IF      IN-CHASSI               =       SPACES
048700             MOVE    002             TO      OUT-COD-RET
048800             GO                      TO      040-S-CONSISTE
048900     ELSE
049000             NEXT    SENTENCE.
049100
049200     IF      IN-CPF-CGC-X            IS      NUMERIC   AND
049300             IN-CPF-CGC              >       0
049400             NEXT    SENTENCE
049500     ELSE
049600             MOVE    027             TO      OUT-COD-RET
049700             GO                      TO      040-S-CONSISTE.
049800
049900*  ---> Limpa tabela
050000
050100     MOVE    SPACES                  TO      TBB-PLACAS.
050200
050300
050400*  ---> Verifica Servicos Pendentes
050500
050600     PERFORM 050-E-SERV-PEN          THRU    050-S-SERV-PEN.
050700
050800     IF      OUT-COD-RET             >       0
050900             GO                      TO      040-S-CONSISTE
051000     ELSE
051100             NEXT    SENTENCE.
051200
051300
051400*  ---> Verifica Placa Personalizada  e Altera p/ LETRA
051500
051600     SET     NOVAPLACSS6             TO      BEGINNING.
051700
051800     PERFORM 060-E-PLA-PER           THRU    060-S-PLA-PER.
051900
052000     IF      OUT-COD-RET             >       0  OR
052010             AX-PLACA-PERSON         =       "X"
