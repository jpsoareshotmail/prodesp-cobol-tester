102000
102100
102200
102300     DISPLAY "* PC/GEV/T430/DB: ERRO  DE  DMS-II  *".
102400     IF      DMSTATUS(NOTFOUND)      DISPLAY "NOTFOUND"    ELSE
102500     IF      DMSTATUS(DUPLICATES)    DISPLAY "DUPLICATES"  ELSE
102600     IF      DMSTATUS(DEADLOCK)      DISPLAY "DEADLOCK"    ELSE
102700     IF      DMSTATUS(KEYCHANGED)    DISPLAY "KEYCHANGED"  ELSE
102800     IF      DMSTATUS(DATAERROR)     DISPLAY "DATAERROR"   ELSE
102900     IF      DMSTATUS(NOTLOCKED)     DISPLAY "NOTLOCKED"   ELSE
103000     IF      DMSTATUS(SYSTEMERROR)   DISPLAY "SYSTEMERROR" ELSE
103100     IF      DMSTATUS(IOERROR)       DISPLAY "IOERROR"     ELSE
103200     IF      DMSTATUS(LIMITERROR)    DISPLAY "LIMITERROR"  ELSE
103300     IF      DMSTATUS(OPENERROR)     DISPLAY "OPENERROR"   ELSE
103400     IF      DMSTATUS(CLOSEERROR)    DISPLAY "CLOSEERROR"  ELSE
103500     IF      DMSTATUS(NORECORD)      DISPLAY "NORECORD"    ELSE
103600     IF      DMSTATUS(INUSE)         DISPLAY "INUSE"       ELSE
103700     IF      DMSTATUS(AUDITERROR)    DISPLAY "AUDITERROR"  ELSE
103800     IF      DMSTATUS(ABORT)         DISPLAY "ABORT".
103900
104000     DISPLAY "STRUCTURE - "          DMSTATUS(DMSTRUCTURE).
104100     DISPLAY "TYPE      - "          DMSTATUS(DMERRORTYPE).
104200
104300     MOVE    968                     TO      OUT-COD-RET.
104400     MOVE    0212                    TO      AX-LENGTH.
104500
104600
