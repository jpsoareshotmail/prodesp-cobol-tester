119600             DISPLAY "T430 : NPL-SORT2  = "  NPL-SORT2
119700             DISPLAY "T430 : NPL-SORT3  = "  NPL-SORT3
119800             DISPLAY "T430 : NPL-PLACA  = "  NPL-LETRA  NPL-NUMERO
