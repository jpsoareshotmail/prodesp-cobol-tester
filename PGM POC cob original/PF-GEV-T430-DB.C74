108300*             LEITURA PRODCRVDS PARA PEGAR DATA DE CORTE         *
108400******************************************************************
108500
108600 190-E-PRODCRV-MERC.
108700
108800     MOVE    "N"                     TO     CH-NOTFOUND.
108900
109000     FIND    PRODCRCSE               AT
109100             CRV-CODIGO              =      9999        AND
109200             CRV-USUARIO             =      "MERCOSUL"
109300       ON    EXCEPTION
109400         IF  DMSTATUS (NOTFOUND)
109500             MOVE    "S"             TO     CH-NOTFOUND
109600             MOVE    SPACES          TO     AX-CRV-MERC
109700             GO                      190-S-PRODCRV-MERC
109800
109900         ELSE
110000             PERFORM 170-E-ERRODB    THRU   170-S-ERRODB
110100             CALL    SYSTEM  DMTERMINATE.
110200
110300     MOVE    CRV-OUTROSCAMPOS        TO     AX-CRV-MERC.
110400
110500
110600 190-S-PRODCRV-MERC.
110700     EXIT.
110800
110900******************************************************************
111000*      TRANSFORMA PLACA COMUM PARA PLACA MERCOSUL E VICE-VERSA   *
111100******************************************************************
111200
111300 200-E-ALTERA-PLACA.
111400
111500     MOVE    NPL-PLACA               TO     AX-PLACA.
111600
111700     SET     IN1                     TO      1.
111800
111900     MOVE    AX-ALFA                 TO     AX-ALFA-ALTER.
112000
112100     IF      AX-DATE-4AMMDD          >      AX-DTCORTE-MERC
112200        IF   AX-ALFA                 IS     ALPHABETIC
112300             NEXT SENTENCE
112400        ELSE
112500            SEARCH  TBA-LET-NUM      AT     END
112600                    MOVE   "N"       TO     AX-ALTEROU
112700            WHEN    TBA-NUM (IN1)    =      AX-ALFA
112800                    MOVE  TBA-LET (IN1)     TO  AX-ALFA-ALTER
112900                    MOVE   "S"       TO     AX-ALTEROU
113000     ELSE
113100        IF   AX-ALFA                 IS     ALPHABETIC
113200             SEARCH  TBA-LET-NUM     AT     END
113300                     MOVE   "N"      TO     AX-ALTEROU
113400             WHEN    TBA-LET (IN1)   =      AX-ALFA
113500                   MOVE    TBA-NUM (IN1)    TO  AX-ALFA-ALTER
113600                   MOVE   "S"        TO     AX-ALTEROU.
113700
113800     MOVE    AX-ALFA-ALTER           TO     AX-ALFA.
113900
114000 200-S-ALTERA-PLACA.
114100     EXIT.
114200
