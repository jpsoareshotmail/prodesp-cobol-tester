160400*               VERIFICA / CAPTURA AUTENTICA¸¶O                  *
160500******************************************************************
160600
160700 160-E-VERAUT.
160800
160900     IF      AX-CPF-CGC      =       ZEROS    AND
161000            (AX-AUT-DUT      =       SPACES OR LOW-VALUES  AND
161100             AX-AUT-EMPL     =       SPACES OR LOW-VALUES)
161200             MOVE  AX-AUT-DUT        TO      OUT-AUT-DUT
161300             MOVE  AX-AUT-EMPL       TO      OUT-AUT-EMPL
161400             GO                      160-S-VERAUT
161500     ELSE
161600     IF      (AX-AUT-DUT     =       SPACES OR LOW-VALUES  AND
161700             AX-AUT-EMPL     =       SPACES OR LOW-VALUES)
161800             MOVE  AX-AUT-DUT        TO      OUT-AUT-DUT
161900             MOVE  AX-AUT-EMPL       TO      OUT-AUT-EMPL
162000             GO                      160-S-VERAUT
162100     ELSE
162200     IF      ((AX-AUT-DUT     =       SPACES OR  LOW-VALUES ) AND
162300             AX-CPF-CGC      NOT =   ZEROS)   OR
162400             ((AX-AUT-EMPL    =       SPACES OR  LOW-VALUES ) AND
162500             AX-CPF-CGC      NOT =   ZEROS)
162600             MOVE  AX-AUT-DUT        TO      OUT-AUT-DUT
162700             MOVE  AX-AUT-EMPL       TO      OUT-AUT-EMPL
162800             GO                      160-S-VERAUT
162900     ELSE
163000     IF      ((AX-AUT-DUT     NOT =   SPACES AND  LOW-VALUES) AND
163100             AX-CPF-CGC      =       ZEROS)   OR
163200             ((AX-AUT-EMPL    NOT =   SPACES OR  LOW-VALUES) AND
163300             AX-CPF-CGC      =       ZEROS)
163400             MOVE  AX-AUT-DUT        TO      OUT-AUT-DUT
163500             MOVE  AX-AUT-EMPL       TO      OUT-AUT-EMPL
163600             GO                      160-S-VERAUT.
163700
163800
163900     IF      AX-CPF-CGC              NOT =   ZEROS    AND
164000             AX-AUT-DUT              NOT =   SPACES   AND
164100             AX-AUT-EMPL             NOT =   SPACES
164200
164300             IF    AX-DUT(8)         NOT =   SPACES   AND
164400                   AX-EMPL(8)        NOT =   SPACES
164500                   MOVE  AX-AUT-DUT          TO      OUT-AUT-DUT
164600                   MOVE  AX-AUT-EMPL         TO      OUT-AUT-EMPL
164700                   GO                        160-S-VERAUT
164800             ELSE
164900                   MOVE  AX-DUT(1)   TO      AX-AUT-DUT-8
165000                   MOVE  AX-EMPL(1)  TO      AX-AUT-EMPL-8.
165100
165200
165300     FIND    FIRST   EAUSENHASE      AT
165400             EAU-SENHA-08            =       AX-AUT-DUT-8   AND
165500             EAU-CPF-CGC             =       AX-CPF-CGC
165600        ON   EXCEPTION
165700             IF   DMSTATUS (NOTFOUND)
165800                  MOVE  IN-AUT-DUT        TO      OUT-AUT-DUT
165900                  GO                      160-VER-EMPL
166000             ELSE
166100                  DISPLAY "PC/GEV/T020/DB : FIND ERROR EAUSENHASE"
166200                  PERFORM 110-E-ERRODB    THRU    110-S-ERRODB
166300                  CALL    SYSTEM          DMTERMINATE.
166400
166500     MOVE    EAU-SENHA               TO      OUT-AUT-DUT.
166600
166700
166800
166900 160-VER-EMPL.
167000
167100      FIND    FIRST   EAUSENHASE     AT
167200             EAU-SENHA-08            =       AX-AUT-EMPL-8   AND
167300             EAU-CPF-CGC             =       AX-CPF-CGC
167400        ON   EXCEPTION
167500             IF   DMSTATUS (NOTFOUND)
167600                  MOVE  IN-AUT-EMPL       TO      OUT-AUT-EMPL
167700                  GO                      160-S-VERAUT
167800             ELSE
167900                  DISPLAY "PC/GEV/T020/DB : FIND ERROR EAUSENHASE"
168000                  PERFORM 110-E-ERRODB    THRU    110-S-ERRODB
168100                  CALL    SYSTEM          DMTERMINATE.
168200
168300
168400     MOVE    EAU-SENHA               TO      OUT-AUT-EMPL.
168500
168600
168700 160-S-VERAUT.
