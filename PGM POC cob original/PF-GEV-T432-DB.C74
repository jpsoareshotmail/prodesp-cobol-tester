100900*      TRANSFORMA PLACA COMUM PARA PLACA MERCOSUL E VICE-VERSA   *
101000******************************************************************
101100
101200 170-E-ALTERA-PLACA.
101300
101400
101500
101600     SET     IN1                     TO      1.
101700
101800     MOVE    AX-ALFA                 TO     AX-ALFA-ALTER.
101900
102000     IF      AX-DATA-MAQ             >      AX-DTCORTE-MERC
102100        IF   AX-ALFA                 IS     ALPHABETIC
102200             NEXT SENTENCE
102300        ELSE
102400            SEARCH  TBA-LET-NUM      AT     END
102500                    MOVE   "N"       TO     AX-ALTEROU
102600            WHEN    TBA-NUM (IN1)    =      AX-ALFA
102700                    MOVE  TBA-LET (IN1)     TO  AX-ALFA-ALTER
102800                    MOVE   "S"       TO     AX-ALTEROU
102900     ELSE
103000        IF   AX-ALFA                 IS     ALPHABETIC
103100             SEARCH  TBA-LET-NUM     AT     END
103200                     MOVE   "N"      TO     AX-ALTEROU
103300             WHEN    TBA-LET (IN1)   =      AX-ALFA
103400                   MOVE    TBA-NUM (IN1)    TO  AX-ALFA-ALTER
103500                   MOVE   "S"        TO     AX-ALTEROU.
103600
103700
103800     MOVE    AX-ALFA-ALTER           TO     AX-ALFA.
103900
104000 170-S-ALTERA-PLACA.
104100     EXIT.
104200
104300
104400 180-E-ALTER-5POS.
104500
104600     SET     IN1                     TO      1.
104700
104800
104900     IF   AX-ALFA                    IS     ALPHABETIC
105000          SEARCH  TBA-LET-NUM        AT     END
105100                  MOVE   "N"         TO     AX-ALTEROU
105200                  MOVE   ZEROS       TO     AX-IN-NUMERO-9
105300          WHEN    TBA-LET (IN1)      =      AX-ALFA
105400                  MOVE  TBA-NUM (IN1)   TO  AX-ALFA
105500                  MOVE  AX-NUMERO    TO     AX-IN-NUMERO-9
105600                  MOVE   "S"         TO     AX-ALTEROU
105700     ELSE
105800          SEARCH  TBA-LET-NUM        AT     END
105900                  MOVE   "N"         TO     AX-ALTEROU
