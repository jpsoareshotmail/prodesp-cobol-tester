060500/
060600******************************************************************
060700*        TRATA  TRANSACAO  DE  VALIDACAO DE AUTENTICACAO         *
060800******************************************************************
060900*
061000 030-E-V432.
061100
061200
061300
061400     MOVE    0                       TO      IA1.
061405     MOVE    SPACES                  TO      AX-NUMLETRA.
061500
061505** VERIFICA DATA MERCOSUL
061510     PERFORM 160-E-PRODCRV-MERC      THRU   160-S-PRODCRV-MERC.
061515
061600     PERFORM 040-E-VERIF-IN          THRU    040-S-VERIF-IN.
061700
061800     IF      IA1                     >       0
061900             GO                      030-S-V432.
062000
062100
062200     IF      (IN-LETRA               NOT =   SPACES AND
062300                                             LOW-VALUES) AND
062400             (IN-NUMEROS-X           NOT =   SPACES AND
062500                                             LOW-VALUES)
062600             PERFORM 050-E-PLACACOMPL        THRU
062700                                     050-S-PLACACOMPL
062800     ELSE
062900     IF      (IN-LETRA               NOT =   SPACES AND
063000                                             LOW-VALUES) AND
063100             (IN-NUMEROS-X           =       ZEROS OR SPACES)
063200             SET  NOVAPLACSS7        TO      BEGINNING
063300             PERFORM 060-E-SO-LETRAS         THRU
063400                                     060-S-SO-LETRAS
063500                     VARYING         IX1     FROM   1   BY    1
063600                     UNTIL           IX1     >      20
063700                     OR              CH-NOTFOUND    =   "S"
063800     ELSE
063900     IF      (IN-NUMEROS             NOT =    SPACES )   AND
064000             (IN-LETRA               =       SPACES)
064100             SET  NOVAPLACSS8        TO      BEGINNING
064200             PERFORM 070-E-SO-NUMEROS        THRU
064300                                     070-S-SO-NUMEROS
064400                     VARYING         IX1     FROM   1   BY    1
064500                     UNTIL           IX1     >      20
064600                     OR              CH-NOTFOUND    =   "S".
064700
064800**** Quando cpo OUT-QTDE-PLACAS = 1 verificar SERPRO
064810     IF      OUT-QTDE-PLACAS         =      1         AND
064815            (CH-LETRA                NOT =  SPACES    AND
064820             CH-NUMERO               NOT =  SPACES AND ZEROS)
064825             PERFORM 200-E-BIN-902   THRU   200-S-BIN-902
064830             IF      IA1             =      624
064835                     PERFORM   210-E-INCL-PLACDS
064840                                     THRU 210-S-INCL-PLACDS.
064845
064850
064900
065000
065100
065200
065300 030-S-V432.
065400     EXIT.
065500
065600/
065700******************************************************************
065800*              VERIFICA  DADOS  DE  PARAMETRO                    *
065900******************************************************************
066000*
066100 040-E-VERIF-IN.
066200
066300     MOVE    IN-PLACA                TO     CH-PLACA.
066305     IF      AX-DATA-MAQ             >      AX-DTCORTE-MERC
066310             PERFORM  190-E-CONSISTE-MERC   THRU
066315                                     190-S-CONSISTE-MERC
066320             GO                      040-S-VERIF-IN.
066400
066500*
066600*==>  VERIFICA SE PLACA PREENCHIDS
066700
066800     IF      (IN-LETRA               =       SPACES     OR
066900                                             ZEROS      OR
067000                                             LOW-VALUES ) AND
067100             (IN-NUMEROS-X           =       SPACES     OR
067200                                             ZEROS      OR
067300                                             LOW-VALUES )
067400             MOVE    001             TO      IA1
067500             GO                      TO      040-S-VERIF-IN.
067600
067700** LETRA em branco  ou alfabetica
067800
067900     IF      (IN-LETRA               IS      ALPHABETIC)  OR
068000             (IN-LETRA               =       SPACES)
068100             NEXT SENTENCE
068200     ELSE
068300             MOVE    002             TO      IA1
068400             GO                      TO      040-S-VERIF-IN.
068500
068600** NUMERO numerico e LETRA preenchida (placa completa)
068700
068800     IF      (IN-NUMEROS-X           NUMERIC )   AND
068900             (IN-LETRA               IS      ALPHABETIC  AND
069000              IN-LETRA               NOT =   SPACES)
069100             NEXT SENTENCE
069200     ELSE
069300** NUMERO numerico e LETRA em branco (so numero)
069400     IF      (IN-NUMEROS-X           NUMERIC )   AND
069500             (IN-LETRA               =       SPACES)
069600              MOVE  IN-NUMEROS       TO     AX-NUMERO
069605             PERFORM  180-E-ALTER-5POS      THRU
069610                                     180-S-ALTER-5POS
069700     ELSE
069800** NUMERO em branco e LETRA preenchida (so letra)
069900     IF      (IN-NUMEROS-X           NOT     NUMERIC AND
069905              IN-NUMEROS-X           =       SPACES)   AND
070000             (IN-LETRA               NOT =   SPACES)
070100              NEXT SENTENCE
070200     ELSE
070300             MOVE    003             TO      IA1
070400             GO                      TO      040-S-VERIF-IN.
070500
070600** LETRA PREENCHIDA VERIFICA INTERVALO
070700
070800     IF      (IN-LETRA               NOT =   SPACES)
070900        IF   (IN-LETRA               NOT <   "BFA"  AND
071000              IN-LETRA               NOT >   "GKI")  OR
071005             (IN-LETRA               NOT <   "QSO"  AND
071010              IN-LETRA               NOT >   "QSZ")  OR
071015             (IN-LETRA               NOT <   "SSR"  AND
071020              IN-LETRA               NOT >   "SWZ")  OR
071025             (IN-LETRA               NOT <   "TIO"  AND
071030              IN-LETRA               NOT >   "TMJ")  OR
071035             (IN-LETRA               NOT <   "UDA"  AND
071040              IN-LETRA               NOT >   "UGV") OR
071041             (IN-LETRA               NOT <   "UOG"  AND
071042              IN-LETRA               NOT >   "USB")
071100             NEXT SENTENCE
071200        ELSE
071300             MOVE    002             TO      IA1
071400             GO                      TO      040-S-VERIF-IN.
071500
071600
071700
071800
071900
072000 040-S-VERIF-IN.
072100     EXIT.
072200
072300
072400/*****************************************************************
072500*        LEITURA NOVAPLACDS  - PLACA COMPLETA                    *
072600******************************************************************
072700
072800 050-E-PLACACOMPL.
072900
073000
073100     MOVE    "N"                     TO      CH-NOTFOUND.
073200
073300     FIND    NOVAPLACSS7             AT
073400             NPL-LETRA               =       IN-LETRA     AND
073500             NPL-NUMERO              =       IN-NUMEROS
073600       ON    EXCEPTION
073700        IF   DMSTATUS (NOTFOUND)
073702             IF   AX-DATA-MAQ        >       AX-DTCORTE-MERC
073704              IF  AX-NUMLETRA        =       "N"
073705                 MOVE "S"            TO      CH-NOTFOUND
073706                 MOVE 004            TO      IA1
073707                 GO                  TO      050-S-PLACACOMPL
073710              ELSE
073712                 SET  NOVAPLACSS7    TO      BEGINNING
073714                 MOVE AX-IN-NUMERO-9 TO      IN-NUMEROS
073716                 MOVE "N"            TO      AX-NUMLETRA
073718                 GO                  TO      050-E-PLACACOMPL
073720             ELSE
073722              IF  AX-NUMLETRA        =       "N"
073724                 MOVE "S"            TO      CH-NOTFOUND
073726                 MOVE 004            TO      IA1
073728                 GO                  TO      050-S-PLACACOMPL
073730              ELSE
073732                 SET  NOVAPLACSS7    TO      BEGINNING
073734                 MOVE AX-IN-NRO-X    TO      IN-NUMEROS
073736                 MOVE "N"            TO      AX-NUMLETRA
073738                 GO                  TO      050-E-PLACACOMPL
073740
074100        ELSE
074200             DISPLAY "PC/GEV/T432/DB: FIND ERROR NOVAPLACSS7"
074300             PERFORM 140-E-ERRODB    THRU    140-S-ERRODB
074400             CALL    SYSTEM          DMTERMINATE.
074500
074600
074700     MOVE    ZEROS                   TO      IA1.
074800     MOVE    1                       TO      OUT-QTDE-PLACAS
074900     MOVE    NPL-LETRA               TO      OUT-LETRA(1).
075000     MOVE    NPL-NUMERO              TO      OUT-NUMEROS(1).
075100
075105** VERIFICA DATA DE CORTE E TRANSFORMA PLACA
075110
075115     MOVE    NPL-PLACA               TO      AX-PLACA.
075120     PERFORM 170-E-ALTERA-PLACA      THRU   170-S-ALTERA-PLACA.
075125     IF      AX-ALTEROU              =      "S"
075130             MOVE AX-LETRA           TO     OUT-LETRA(1)
075135             MOVE AX-NUMERO          TO     OUT-NUMEROS(1).
075140
075200
075300 050-S-PLACACOMPL.
075400     EXIT.
075500
075600
075700
075800
075900******************************************************************
076000*              LEITURA NOVAPLACDS SO LETRA                       *
076100******************************************************************
076200
076300 060-E-SO-LETRAS.
076400
076500
076600
076700     MOVE    "N"                     TO      CH-NOTFOUND.
076800
076900     FIND    NEXT   NOVAPLACSS7      AT
077000             NPL-LETRA               =       IN-LETRA
077100       ON    EXCEPTION
077200        IF   DMSTATUS (NOTFOUND)
077300             IF  OUT-QTDE-PLACAS     >       ZEROS
077400                 MOVE "S"            TO      CH-NOTFOUND
077500                 GO                  060-S-SO-LETRAS
077600             ELSE
077700                 MOVE    "S"         TO      CH-NOTFOUND
077800                 MOVE    004         TO      IA1
077900                 GO                  060-S-SO-LETRAS
078000        ELSE
078100             DISPLAY "PC/GEV/T432/DB: FIND ERROR NOVAPLACSS7"
078200             PERFORM 140-E-ERRODB    THRU    140-S-ERRODB
078300             CALL    SYSTEM          DMTERMINATE.
078400
078500     MOVE    ZEROS                   TO      IA1.
078600     ADD     1                       TO      OUT-QTDE-PLACAS
078700     MOVE    NPL-LETRA               TO      OUT-LETRA(IX1).
078800     MOVE    NPL-NUMERO              TO      OUT-NUMEROS(IX1).
078900
078905** VERIFICA DATA DE CORTE E TRANSFORMA PLACA
078910
078915     MOVE    NPL-PLACA               TO      AX-PLACA.
078920     PERFORM 170-E-ALTERA-PLACA      THRU   170-S-ALTERA-PLACA.
078925     IF      AX-ALTEROU              =      "S"
078930             MOVE AX-LETRA           TO     OUT-LETRA(IX1)
078935             MOVE AX-NUMERO          TO     OUT-NUMEROS(IX1).
079000
079100 060-S-SO-LETRAS.
079200     EXIT.
079300
079400/*****************************************************************
079500*                LEITURA NOVAPLACDS SO NUMEROS                   *
079600******************************************************************
079700
079800 070-E-SO-NUMEROS.
079900
080000     MOVE    "N"                     TO      CH-NOTFOUND.
080100
080200     FIND    NEXT   NOVAPLACSS8      AT
080300             NPL-NUMERO              =       IN-NUMEROS
080400       ON    EXCEPTION
080500        IF   DMSTATUS (NOTFOUND)
080520             IF     OUT-QTDE-PLACAS  >       ZEROS
080540                 MOVE "S"            TO      CH-NOTFOUND
080560                 GO                  TO      070-S-SO-NUMEROS
080580             ELSE
080600              IF    AX-DATA-MAQ      >       AX-DTCORTE-MERC
080620               IF   AX-NUMLETRA      =       "N"
080640                 MOVE "S"            TO      CH-NOTFOUND
080660                 MOVE 004            TO      IA1
080680                 GO                  TO      070-S-SO-NUMEROS
080805               ELSE
080810                 SET  NOVAPLACSS8    TO      BEGINNING
080815                 MOVE AX-IN-NUMERO-9 TO      IN-NUMEROS
080820                 MOVE "N"            TO      AX-NUMLETRA
080825                 GO                  TO      070-E-SO-NUMEROS
080900              ELSE
080905               IF    AX-NUMLETRA     =       "N"
081000                 MOVE "S"            TO      CH-NOTFOUND
