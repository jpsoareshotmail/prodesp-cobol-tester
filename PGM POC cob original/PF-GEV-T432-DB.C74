107000******************************************************************
107100*              CONSISTE ENTRADA QDO DA ENTRADA PLACA MERC        *
107200******************************************************************
107300
107400 190-E-CONSISTE-MERC.
107500
107600
107700*
107800*==>  VERIFICA SE PLACA PREENCHIDOS
107900
108000     IF      (IN-LETRA               =       SPACES     OR
108100                                             ZEROS      OR
108200                                             LOW-VALUES ) AND
108300             (IN-NUMEROS-X           =       SPACES     OR
108400                                             ZEROS      OR
108500                                             LOW-VALUES )
108600             MOVE    001             TO      IA1
108700             GO                      190-S-CONSISTE-MERC.
108800
108900** LETRA em branco  ou alfabetica
109000
109100     IF      (IN-LETRA               IS      ALPHABETIC)  OR
109200             (IN-LETRA               =       SPACES)
109300             NEXT SENTENCE
109400     ELSE
109500             MOVE    002             TO      IA1
109600             GO                      190-S-CONSISTE-MERC.
109700
109800** NUMERO numerico e LETRA preenchida (placa completa)
109900
110000     IF      (IN-NUMEROS-X           NOT     NUMERIC      AND
110100             IN-NUMEROS-X            NOT =   SPACES  )    AND
110200             (IN-LETRA               IS      ALPHABETIC  AND
110300              IN-LETRA               NOT =   SPACES)
110400             MOVE  IN-NUMEROS       TO     AX-NUMERO
110500             PERFORM  180-E-ALTER-5POS      THRU
110600                                     180-S-ALTER-5POS
110700     ELSE
110800** NUMERO Preenchido e LETRA em branco
110900     IF      (IN-NUMEROS-X           NOT     NUMERIC   AND
111000              IN-NUMEROS             >       SPACES )    AND
111100             (IN-LETRA               =       SPACES)
111200              MOVE  IN-NUMEROS       TO     AX-NUMERO
111300             PERFORM  180-E-ALTER-5POS      THRU
111400                                     180-S-ALTER-5POS
111500     ELSE
111600** NUMERO em branco e LETRA preenchida (so letra)
111700     IF      (IN-NUMEROS-X           =       SPACES )   AND
111800             (IN-LETRA               NOT =   SPACES)
111900              NEXT SENTENCE
112000     ELSE
112100             MOVE    003             TO      IA1
112200             GO                      190-S-CONSISTE-MERC.
112300
112400** LETRA PREENCHIDA VERIFICA INTERVALO
112500
112600     IF      (IN-LETRA               NOT =   SPACES)
112700        IF   (IN-LETRA               NOT <   "BFA"  AND
112800              IN-LETRA               NOT >   "GKI")  OR
112810             (IN-LETRA               NOT <   "QSO"  AND
112820              IN-LETRA               NOT >   "QSZ")  OR
112830             (IN-LETRA               NOT <   "SSR"  AND
112840              IN-LETRA               NOT >   "SWZ")  OR
112850             (IN-LETRA               NOT <   "TIO"  AND
112860              IN-LETRA               NOT >   "TMJ")  OR
112870             (IN-LETRA               NOT <   "UDA"  AND
112880              IN-LETRA               NOT >   "UGV")  OR
112885             (IN-LETRA               NOT <   "UOG"  AND
112890              IN-LETRA               NOT >   "USB")
112900             NEXT SENTENCE
113000        ELSE
113100             MOVE    002             TO      IA1
113200             GO                      190-S-CONSISTE-MERC.
113300
113400
113500 190-S-CONSISTE-MERC.
113600     EXIT.
113700
