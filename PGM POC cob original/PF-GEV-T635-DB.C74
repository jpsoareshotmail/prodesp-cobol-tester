081400/
081500******************************************************************
081600*        ROTINA    MONITORA    DO    PROGRAMA                    *
081700******************************************************************
081900 000-MONITORA    SECTION.
082000
082100 000-E-MONITORA.
082200
082300
082400
082500     PERFORM 010-E-INICIO            THRU   010-S-INICIO.
082600
082700
082800     PERFORM 020-E-PROCESSA          THRU   020-S-PROCESSA
082900             UNTIL   COMS-IN-STATUS  =      99.
083000
083100
083200     PERFORM 900-E-FINAL             THRU   900-S-FINAL.
083300
083400
083500
083600 000-S-MONITORA.
083700     STOP    RUN.
083800
083900/
084000******************************************************************
084100*                   INICIALIZACAO                                *
084200******************************************************************
084400 010-E-INICIO.
084700
084800     MOVE    ATTRIBUTE NAME OF ATTRIBUTE EXCEPTIONTASK
084900                            OF ATTRIBUTE EXCEPTIONTASK OF MYSELF
085000                            TO LINKTOCOMS.
085200
085300     CHANGE  ATTRIBUTE TITLE OF "DCILIBRARY" TO LINKTOCOMS.
085400
085500
085600     ENABLE  INPUT   COMS-IN         KEY    "ONLINE"
085700
085800     CALL    "GET_DESIGNATOR_USING_NAME  IN DCILIBRARY"
085900                                     USING  AX-AGENDA-OUT,
086000                                     VALUE  AGENDA,
086100                                            AX-AGENDA-DESG
086200                                     GIVING AX-CALL-ERROR.
086600
086700     OPEN    UPDATE      DB01
086800       ON    EXCEPTION
086900             DISPLAY "PC/GEV/T635/DB : OPEN ERROR TDBGEVER"
087000             PERFORM 160-E-ERRODB    THRU    160-S-ERRODB
087100             CALL    SYSTEM          DMTERMINATE.
087300
087400     OPEN    INQUIRY     DB02
087500       ON    EXCEPTION
087600             DISPLAY "PC/GEV/T635/DB : OPEN ERROR TTABELAS"
087700             PERFORM 160-E-ERRODB    THRU    160-S-ERRODB
087800             CALL    SYSTEM          DMTERMINATE.
088000
088100     OPEN    INQUIRY     DB03
088200       ON    EXCEPTION
088300             DISPLAY "PC/GEV/T635/DB : OPEN ERROR TDBDETRAN"
088400             PERFORM 160-E-ERRODB    THRU    160-S-ERRODB
088500             CALL    SYSTEM          DMTERMINATE.
088520
088530     OPEN    UPDATE      DB04
088540       ON    EXCEPTION
088550             DISPLAY "PC/GEV/T635/DB : OPEN ERROR TDBTAXAS"
088560             PERFORM 160-E-ERRODB    THRU    160-S-ERRODB
088570             CALL    SYSTEM          DMTERMINATE.
088900
089000 010-S-INICIO.
089100     EXIT.
089200
089300/
089400******************************************************************
089500*                P R O C E S S A M E N T O                       *
089600******************************************************************
089800 020-E-PROCESSA.
089900
090000
090100
090200     MOVE    SPACES                  TO     AREA-IN
090300                                            AREA-OUT.
090400
090500     RECEIVE COMS-IN MESSAGE         INTO   AREA-IN.
090600
090700     IF      COMS-IN-STATUS          =      0 OR 92 OR 93
090800             NEXT    SENTENCE
090900     ELSE
091000     IF      COMS-IN-STATUS          =      99
