057000/
057100******************************************************************
057200*        TRATA  TRANSACAO  DE  VALIDACAO DE AUTENTICACAO         *
057300******************************************************************
057400*
057500 030-E-V446.
057600
057700
057800
057900     MOVE    0                       TO      IA1
058000                                             AX-PRIMVEZ.
058005
058100     PERFORM 040-E-VERIF-IN          THRU    040-S-VERIF-IN.
058200
058300     IF      IA1                     >       0
058400             GO                      030-S-V446.
058500
058600      IF      IN-PLACA                =      SPACES     OR
058620                                             ZEROS      OR
058640                                             LOW-VALUES
058700             MOVE   0                TO      IX1 OUT-QTDE-TAX
058800             SET    TAXCPFSS1        TO      BEGINNING
058900
059000             PERFORM 060-E-FIND-TAXAS  THRU    060-S-FIND-TAXAS
059100      ELSE
059110             MOVE   0                TO      OUT-QTDE-TAX
059140             SET    TAXPLACASS1      TO      BEGINNING
059160
059180             PERFORM 070-E-TAXA-PLACA  THRU  070-S-TAXA-PLACA
059185
059190             IF      CH-NOTFOUND      =      "N"
059195                     MOVE       "S"   TO       CH-NOTFOUND-NPL
059196                     SET    NOVAPLACSE2      TO      BEGINNING
059200                     PERFORM       080-E-NOVAPLACA    THRU
059210                                   080-S-NOVAPLACA
059220                 IF  CH-NOTFOUND-NPL     =     "N"
059230                     NEXT       SENTENCE
059240                 ELSE
059300                     MOVE   0        TO      IX1 OUT-QTDE-TAX
059310                     SET    TAXCPFSS1        TO      BEGINNING
059320                      PERFORM 060-E-FIND-TAXAS       THRU
059400                              060-S-FIND-TAXAS.
059500
059600 030-S-V446.
059700     EXIT.
