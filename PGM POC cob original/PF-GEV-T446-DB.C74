076510              ADD     1                       TO     IX1
076600              MOVE    TAX-COD-BANCO   TO     OUT-COD-BCO(IX1)
076700
076800              MOVE    TAX-DT-CONTB    TO     OUT-DTA-CONTAB(IX1)
076900
077000             MOVE    TAX-NSU-PROD     TO     OUT-NSU-PRODESP(IX1)
077100             MOVE    1                        TO     AX-PRIMVEZ.
077110
077200     GO                 060-LER-FIND-TAXAS.
077300
077400
077500
077600
077700 060-S-FIND-TAXAS.
077800     EXIT.
077900
078000 070-E-TAXA-PLACA.
078002
078004     MOVE    "S"                     TO      CH-NOTFOUND.
078006
078008 070-LER-TAXA-PLACA.
078010
078012     FIND    NEXT   TAXPLACASS1    AT
078014             TAX-SITUACAO            =       3          AND
078016             TAX-PLACA-MERC          =       IN-PLACA   AND
078018             TAX-COD-PAG             =       92
078020       ON    EXCEPTION
078022       IF    DMSTATUS (NOTFOUND)
078024             MOVE      "N"           TO      CH-NOTFOUND
078026*****        MOVE      463           TO      IA1
078028             GO                      TO      070-S-TAXA-PLACA
078030       ELSE
078032             DISPLAY "PC/GEV/T466/DB: FIND ERROR TAXPLACASS1"
078034             PERFORM 140-E-ERRODB    THRU    140-S-ERRODB
078036             CALL    SYSTEM          DMTERMINATE.
078038
078040     IF      IN-CNPJ-PROP           =      TAX-CPF-CGC
078042             MOVE   TAX-COD-BANCO   TO     OUT-COD-BCO(1)
078044             MOVE   TAX-NSU-PROD    TO     OUT-NSU-PRODESP(1)
078046             MOVE   TAX-DT-CONTB    TO     OUT-DTA-CONTAB(1)
078048             MOVE   1               TO     OUT-QTDE-TAX
078050                                           IX1
078052     ELSE
078054             GO                     TO     070-LER-TAXA-PLACA.
078056
078058
078060
078062 070-S-TAXA-PLACA.
078064     EXIT.
078066
078100 080-E-NOVAPLACA.
078105     FIND     NEXT      NOVAPLACSE2         AT
078110              NPL-CHASSI          =       IN-CHASSI
078115       ON    EXCEPTION
078120       IF    DMSTATUS (NOTFOUND)
078125             MOVE       "N"         TO       CH-NOTFOUND-NPL
078130             MOVE      463           TO      IA1
078135             GO                      TO      080-S-NOVAPLACA
078140       ELSE
078145             DISPLAY "PC/GEV/T466/DB: FIND ERROR NOVAPLACSE2"
078150             PERFORM 140-E-ERRODB    THRU    140-S-ERRODB
078155             CALL    SYSTEM          DMTERMINATE.
078160
078165      IF     NPL-PLACA     =       IN-PLACA
078170             NEXT       SENTENCE
078175      ELSE
078180             GO            TO      080-E-NOVAPLACA.
078185
078190 080-S-NOVAPLACA.
078195     EXIT.
