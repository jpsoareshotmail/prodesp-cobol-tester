854800*
854900*
855000*    IF      CH-LAUDO                =       "N"
855050*      IF    PLC-UF-PLACA-ANT        NOT =   "SP"   AND
855060*                                            SPACES AND
855070*                                            LOW-VALUES
855100*            GO                      TO      790-S-VISTORIA
855120*      ELSE
855140*            MOVE    142             TO      IA1
855160*            MOVE    "*"             TO      CH-ERRO
855180*            GO                      TO      790-S-VISTORIA
855200*    ELSE
855205*            NEXT    SENTENCE.
855206*
855208*    IF      VIS-RESULTADO           =       1  OR  2
855240*        IF  VIS-DT-VALIDADE         <       AX-DATAHOJE-AMD
855288*            MOVE    143             TO      IA1
855290*            MOVE    "*"             TO      CH-ERRO
855292*            GO                      TO      790-S-VISTORIA
855298*       ELSE
855300*            NEXT    SENTENCE
855302*    ELSE
855304*            NEXT    SENTENCE.
855306*
855308*
855310*    IF      VIS-RESULTADO           =       1
855400*            MOVE    "A"             TO      CH-LAUDO
855500*            MOVE    VIS-DT-INCLUSAO TO      CH-DT-VIST
855600*            MOVE    VIS-HR-INCLUSAO TO      CH-HR-VIST
855700*    ELSE
855800*    IF      VIS-RESULTADO           =       2
855900*            MOVE    "P"             TO      CH-LAUDO
856000*            MOVE    VIS-DT-INCLUSAO TO      CH-DT-VIST
856100*            MOVE    VIS-HR-INCLUSAO TO      CH-HR-VIST
856200*    ELSE
856300*            MOVE    VIS-DT-VALIDADE TO      AX-DATA-4AMMDD
856400*            MOVE    AX-4AMMDD-ANO   TO      AX-DDMM4A-ANO
856500*            MOVE    AX-4AMMDD-MES   TO      AX-DDMM4A-MES
856600*            MOVE    AX-4AMMDD-DIA   TO      AX-DDMM4A-DIA
856700*            MOVE    AX-DATA-DDMM4A  TO      AX-FORM-DATA
856800*    IF      VIS-RESULTADO           =       3
856900*            MOVE    VIS-NUMERO      TO      TBA-131-LAUDO
857000*            MOVE    AX-FORM-DATA    TO      TBA-131-DT-VAL
857100*            MOVE    131             TO      IA1
857200*            MOVE    "*"             TO      CH-ERRO
857300*    ELSE
857400*    IF      VIS-RESULTADO           =       4
857500*            MOVE    VIS-NUMERO      TO      TBA-132-LAUDO
857600*            MOVE    AX-FORM-DATA    TO      TBA-132-DT-VAL
857700*            MOVE    132             TO      IA1
857800*            MOVE    "*"             TO      CH-ERRO
857900*    ELSE
858000*            NEXT    SENTENCE.
858100*
858200*
