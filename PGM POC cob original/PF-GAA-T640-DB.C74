285400******************************************************************
285500*
285600
285700 0000-E-MONITOR SECTION.
285800
285900
286000 0000-1-INICIO.
286100
286200     IF  ATTRIBUTE RESTARTED  OF MYSELF =  VALUE TRUE
286300             DISPLAY "GAAT640: TERMINO NORMAL"
286400             GO  TO      0000-S-MONITOR.
286500
286600
286700 0000-2-INICIALIZACAO.
286800
286900     PERFORM 1000-E-INICIAL THRU 1000-S-INICIAL.
287000
287100
287200 0000-3-PROCESSAMENTO.
287300
287302     PERFORM  2000-E-PROCESSO THRU 2000-S-PROCESSO
287303          UNTIL STATUSVALUE OF COMS-IN = 99.
287700
287800 0000-4-FINALIZACAO.
287900
288000     PERFORM 3000-E-FINAL THRU 3000-S-FINAL.
288100
288200
288300 0000-S-MONITOR.
288400
288500     STOP    RUN.
