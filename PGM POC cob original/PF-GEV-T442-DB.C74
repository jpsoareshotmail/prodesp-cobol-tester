071600/
071700******************************************************************
071800*              VERIFICA  DADOS  DE  PARAMETRO                    *
071900******************************************************************
072000*
072100 040-E-VERIF-IN.
072200
072300     MOVE    IN-PLACA                TO     CH-PLACA.
072305*
072400     IF      AX-DATA-MAQ             >      AX-DTCORTE-MERC
072500             PERFORM  190-E-CONSISTE-MERC   THRU
072600                                     190-S-CONSISTE-MERC
072700             GO                      040-S-VERIF-IN.
072800
072900*
073000*==>  VERIFICA SE PLACA PREENCHIDS
073100
073200     IF      (IN-LETRA               =       SPACES     OR
073300                                             ZEROS      OR
073400                                             LOW-VALUES ) AND
073500             (IN-NUMEROS-X           =       SPACES     OR
073600                                             ZEROS      OR
073700                                             LOW-VALUES )
073800             MOVE    001             TO      IA1
073900             GO                      TO      040-S-VERIF-IN.
074000
074100** LETRA em branco  ou alfabetica
074200
074300     IF      (IN-LETRA               IS      ALPHABETIC)  OR
074400             (IN-LETRA               =       SPACES)
074500             NEXT SENTENCE
074600     ELSE
074700             MOVE    002             TO      IA1
074800             GO                      TO      040-S-VERIF-IN.
074900
075000** NUMERO numerico e LETRA preenchida (placa completa)
075100
075200     IF      (IN-NUMEROS-X           NUMERIC )   AND
075300             (IN-LETRA               IS      ALPHABETIC  AND
075400              IN-LETRA               NOT =   SPACES)
075500             NEXT SENTENCE
075600     ELSE
075700** NUMERO numerico e LETRA em branco (so numero)
075800     IF      (IN-NUMEROS-X           NUMERIC )   AND
075900             (IN-LETRA               =       SPACES)
076000              MOVE  IN-NUMEROS       TO     AX-NUMERO
076100             PERFORM  180-E-ALTER-5POS      THRU
076200                                     180-S-ALTER-5POS
076300     ELSE
076400** NUMERO em branco e LETRA preenchida (so letra)
076500     IF      (IN-NUMEROS-X           NOT     NUMERIC AND
076600              IN-NUMEROS-X           =       SPACES)   AND
076700             (IN-LETRA               NOT =   SPACES)
076800              NEXT SENTENCE
076900     ELSE
077000             MOVE    003             TO      IA1
077100             GO                      TO      040-S-VERIF-IN.
077200
077300** LETRA PREENCHIDA VERIFICA INTERVALO
077400
077500     IF      (IN-LETRA               NOT =   SPACES)
077600        IF   (IN-LETRA               NOT <   "BFA"  AND
077700              IN-LETRA               NOT >   "GKI")  OR
077710             (IN-LETRA               NOT <   "QSO"  AND
077720              IN-LETRA               NOT >   "QSZ")  OR
077730             (IN-LETRA               NOT <   "SSR"  AND
077740              IN-LETRA               NOT >   "SWZ")  OR
077750             (IN-LETRA               NOT <   "TIO"  AND
077760              IN-LETRA               NOT >   "TMJ")  OR
077770             (IN-LETRA               NOT <   "UDA"  AND
077780              IN-LETRA               NOT >   "UGV")  OR
077782             (IN-LETRA               NOT <   "UOG"  AND
077784              IN-LETRA               NOT >   "USB")
077800             NEXT SENTENCE
077900        ELSE
078000             MOVE    002             TO      IA1
078100             GO                      TO      040-S-VERIF-IN.
078200
078300
078400
078500
078600
078700 040-S-VERIF-IN.
078800     EXIT.
078900
