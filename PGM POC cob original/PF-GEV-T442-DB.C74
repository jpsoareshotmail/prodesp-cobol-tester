066200******************************************************************
066300*        TRATA  TRANSACAO  DE  VALIDACAO DE AUTENTICACAO         *
066400******************************************************************
066500*
066600 030-E-V442.
066700
066800
066900
067000     MOVE    0                       TO      IA1.
067100     MOVE    SPACES                  TO      AX-NUMLETRA.
067200
067300** VERIFICA DATA MERCOSUL
067400     PERFORM 160-E-PRODCRV-MERC      THRU   160-S-PRODCRV-MERC.
067500
067600     PERFORM 040-E-VERIF-IN          THRU    040-S-VERIF-IN.
067700
067800     IF      IA1                     >       0
067900             GO                      030-S-V442.
068000
068100
068200     IF      (IN-LETRA               NOT =   SPACES AND
068300                                             LOW-VALUES) AND
068400             (IN-NUMEROS-X           NOT =   SPACES AND
068500                                             LOW-VALUES)
068600             PERFORM 050-E-PLACACOMPL        THRU
068700                                     050-S-PLACACOMPL
068800     ELSE
068900     IF      (IN-LETRA               NOT =   SPACES AND
069000                                             LOW-VALUES) AND
069100             (IN-NUMEROS-X           =       ZEROS OR SPACES)
069200             SET  NOVAPLACSS7        TO      BEGINNING
069300             PERFORM 060-E-SO-LETRAS         THRU
069400                                     060-S-SO-LETRAS
069500                     VARYING         IX1     FROM   1   BY    1
069600                     UNTIL           IX1     >      20
069700                     OR              CH-NOTFOUND    =   "S"
069800     ELSE
069900     IF      (IN-NUMEROS             NOT =    SPACES )   AND
070000             (IN-LETRA               =       SPACES)
070100             SET  NOVAPLACSS8        TO      BEGINNING
070200             PERFORM 070-E-SO-NUMEROS        THRU
070300                                     070-S-SO-NUMEROS
070400                     VARYING         IX1     FROM   1   BY    1
070500                     UNTIL           IX1     >      20
070600                     OR              CH-NOTFOUND    =   "S".
070700
070800
070900
070905*** Quando cpo OUT-QTDE-PLACAS = 1 verificar SERPRO
070910
070915     IF      OUT-QTDE-PLACAS         =      1    AND
070920            (AX-LETRA                NOT =  SPACES    AND
070925             AX-NUMERO               NOT =  SPACES AND ZEROS)
070930             PERFORM 200-E-BIN-902   THRU   200-S-BIN-902
070935             IF      IA1             =      624
070940                     PERFORM 210-E-INCL-PLACDS
070945                                     THRU 210-S-INCL-PLACDS.
071000
071100
071200
071300 030-S-V442.
071400     EXIT.
