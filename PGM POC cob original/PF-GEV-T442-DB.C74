120000
120100
120200* ROTINA p/ Placas Mercosul (com letras)
120300*==>  VERIFICA SE PLACA PREENCHIDOS
120400
120500     IF      (IN-LETRA               =       SPACES     OR
120600                                             ZEROS      OR
120700                                             LOW-VALUES ) AND
120800             (IN-NUMEROS-X           =       SPACES     OR
120900                                             ZEROS      OR
121000                                             LOW-VALUES )
121100             MOVE    001             TO      IA1
121200             GO                      190-S-CONSISTE-MERC.
121300
121400** LETRA em branco  ou alfabetica
121500
121600     IF      (IN-LETRA               IS      ALPHABETIC)  OR
121700             (IN-LETRA               =       SPACES)
121800             NEXT SENTENCE
121900     ELSE
122000             MOVE    002             TO      IA1
122100             GO                      190-S-CONSISTE-MERC.
122200
122300** NUMERO numerico e LETRA preenchida (placa completa)
122400
122500     IF      (IN-NUMEROS-X           NOT     NUMERIC      AND
122600             IN-NUMEROS-X            NOT =   SPACES  )    AND
122700             (IN-LETRA               IS      ALPHABETIC  AND
122800              IN-LETRA               NOT =   SPACES)
122900             MOVE  IN-NUMEROS       TO     AX-NUMERO
123000             PERFORM  180-E-ALTER-5POS      THRU
123100                                     180-S-ALTER-5POS
123200     ELSE
123300** NUMERO Preenchido e LETRA em branco
123400     IF      (IN-NUMEROS-X           NOT     NUMERIC   AND
123500              IN-NUMEROS             >       SPACES)    AND
123600             (IN-LETRA               =       SPACES)
123700              MOVE  IN-NUMEROS       TO     AX-NUMERO
123800             PERFORM  180-E-ALTER-5POS      THRU
123900                                     180-S-ALTER-5POS
124000     ELSE
124100** NUMERO em branco e LETRA preenchida (so letra)
124200     IF      (IN-NUMEROS-X           =       SPACES )   AND
124300             (IN-LETRA               NOT =   SPACES)
124400              NEXT SENTENCE
124500     ELSE
124600             MOVE    003             TO      IA1
124700             GO                      190-S-CONSISTE-MERC.
124800
124900** LETRA PREENCHIDA VERIFICA INTERVALO
125000
125100     IF      (IN-LETRA               NOT =   SPACES)
125200        IF   (IN-LETRA               NOT <   "BFA"  AND
125300              IN-LETRA               NOT >   "GKI")  OR
125310             (IN-LETRA               NOT <   "QSO"  AND
125320              IN-LETRA               NOT >   "QSZ")  OR
125330             (IN-LETRA               NOT <   "SSR"  AND
125340              IN-LETRA               NOT >   "SWZ")  OR
125350             (IN-LETRA               NOT <   "TIO"  AND
125360              IN-LETRA               NOT >   "TMJ")  OR
125370             (IN-LETRA               NOT <   "UDA"  AND
125380              IN-LETRA               NOT >   "UGV")  OR
125382             (IN-LETRA               NOT <   "UOG"  AND
125384              IN-LETRA               NOT >   "USB")
125400             NEXT SENTENCE
125500        ELSE
125600             MOVE    002             TO      IA1
125700             GO                      190-S-CONSISTE-MERC.
125800
125900
126000 190-S-CONSISTE-MERC.
126100     EXIT.
