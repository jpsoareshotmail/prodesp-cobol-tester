079400
079500 050-E-PLACACOMPL.
079600
079700
079800     MOVE    "N"                     TO      CH-NOTFOUND.
079900
080000     FIND    NOVAPLACSS7             AT
080100             NPL-LETRA               =       IN-LETRA     AND
080200             NPL-NUMERO              =       IN-NUMEROS
080300       ON    EXCEPTION
080400        IF   DMSTATUS (NOTFOUND)
080500             IF   AX-DATA-MAQ        >       AX-DTCORTE-MERC
080600              IF  AX-NUMLETRA        =       "N"
080700                 MOVE "S"            TO      CH-NOTFOUND
080800                 MOVE 004            TO      IA1
080900                 GO                  TO      050-S-PLACACOMPL
081000              ELSE
081100                 SET  NOVAPLACSS7    TO      BEGINNING
081200                 MOVE AX-IN-NUMERO-9 TO      IN-NUMEROS
081300                 MOVE "N"            TO      AX-NUMLETRA
081400                 GO                  TO      050-E-PLACACOMPL
081500             ELSE
081600              IF  AX-NUMLETRA        =       "N"
081700                 MOVE "S"            TO      CH-NOTFOUND
081800                 MOVE 004            TO      IA1
081900                 GO                  TO      050-S-PLACACOMPL
082000              ELSE
082100                 SET  NOVAPLACSS7    TO      BEGINNING
082200                 MOVE AX-IN-NRO-X    TO      IN-NUMEROS
082300                 MOVE "N"            TO      AX-NUMLETRA
082400                 GO                  TO      050-E-PLACACOMPL
082500
082600        ELSE
082700             DISPLAY "PC/GEV/T442/DB: FIND ERROR NOVAPLACSS7"
082800             PERFORM 140-E-ERRODB    THRU    140-S-ERRODB
082900             CALL    SYSTEM          DMTERMINATE.
083000
083100
083200     MOVE    ZEROS                   TO      IA1.
083300     MOVE    1                       TO      OUT-QTDE-PLACAS
083400     MOVE    NPL-LETRA               TO      OUT-LETRA(1).
083500     MOVE    NPL-NUMERO              TO      OUT-NUMEROS(1).
083600
083700** VERIFICA DATA DE CORTE E TRANSFORMA PLACA
083800
083900     MOVE    NPL-PLACA               TO      AX-PLACA.
084000     PERFORM 170-E-ALTERA-PLACA      THRU   170-S-ALTERA-PLACA.
084100     IF      AX-ALTEROU              =      "S"
084200             MOVE AX-LETRA           TO     OUT-LETRA(1)
084300             MOVE AX-NUMERO          TO     OUT-NUMEROS(1).
084400
084500
084600 050-S-PLACACOMPL.
084700     EXIT.
084800
084900
085000
085100
085200******************************************************************
085300*              LEITURA NOVAPLACDS SO LETRA                       *
085400******************************************************************
085500
085600 060-E-SO-LETRAS.
085700
085800
085900
086000     MOVE    "N"                     TO      CH-NOTFOUND.
086100
086200     FIND    NEXT   NOVAPLACSS7      AT
086300             NPL-LETRA               =       IN-LETRA
086400       ON    EXCEPTION
086500        IF   DMSTATUS (NOTFOUND)
086600             IF  OUT-QTDE-PLACAS     >       ZEROS
086700                 MOVE "S"            TO      CH-NOTFOUND
086800                 GO                  060-S-SO-LETRAS
086900             ELSE
087000                 MOVE    "S"         TO      CH-NOTFOUND
087100                 MOVE    004         TO      IA1
087200                 GO                  060-S-SO-LETRAS
087300        ELSE
087400             DISPLAY "PC/GEV/T442/DB: FIND ERROR NOVAPLACSS7"
087500             PERFORM 140-E-ERRODB    THRU    140-S-ERRODB
087600             CALL    SYSTEM          DMTERMINATE.
087700
087800     MOVE    ZEROS                   TO      IA1.
087900     ADD     1                       TO      OUT-QTDE-PLACAS
088000     MOVE    NPL-LETRA               TO      OUT-LETRA(IX1).
088100     MOVE    NPL-NUMERO              TO      OUT-NUMEROS(IX1).
088200
088300** VERIFICA DATA DE CORTE E TRANSFORMA PLACA
088400
088500     MOVE    NPL-PLACA               TO      AX-PLACA.
088600     PERFORM 170-E-ALTERA-PLACA      THRU   170-S-ALTERA-PLACA.
088700     IF      AX-ALTEROU              =      "S"
088800             MOVE AX-LETRA           TO     OUT-LETRA(IX1)
088900             MOVE AX-NUMERO          TO     OUT-NUMEROS(IX1).
089000
089100 060-S-SO-LETRAS.
089200     EXIT.
089300
089400/*****************************************************************
089500*                LEITURA NOVAPLACDS SO NUMEROS                   *
089600******************************************************************
089700
089800 070-E-SO-NUMEROS.
089900
090000     MOVE    "N"                     TO      CH-NOTFOUND.
090100
090200     FIND    NEXT   NOVAPLACSS8      AT
090300             NPL-NUMERO              =       IN-NUMEROS
090400       ON    EXCEPTION
090500        IF   DMSTATUS (NOTFOUND)
090600             IF     OUT-QTDE-PLACAS  >       ZEROS
090700                 MOVE "S"            TO      CH-NOTFOUND
090800                 GO                  TO      070-S-SO-NUMEROS
090900             ELSE
091000              IF    AX-DATA-MAQ      >       AX-DTCORTE-MERC
091100               IF   AX-NUMLETRA      =       "N"
091200                 MOVE "S"            TO      CH-NOTFOUND
091300                 MOVE 004            TO      IA1
091400                 GO                  TO      070-S-SO-NUMEROS
091500               ELSE
091600                 SET  NOVAPLACSS8    TO      BEGINNING
091700                 MOVE AX-IN-NUMERO-9 TO      IN-NUMEROS
091800                 MOVE "N"            TO      AX-NUMLETRA
091900                 GO                  TO      070-E-SO-NUMEROS
092000              ELSE
092100               IF    AX-NUMLETRA     =       "N"
