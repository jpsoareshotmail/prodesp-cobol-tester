089800*       ROTINA DE ERRO DE LEITURA                                *
089900******************************************************************
090000
090100 550-E-ERRO-IN.
090200
090300     DISPLAY "GEV/T445 - PROBLEMAS NO COMS-IN".
090400     DISPLAY "FUNCTIONINDEX = "     IN-FUNCTION-INDEX.
090500     IF      IN-STATUS               =           20  OR  100   OR
090600                                                 101 OR  102
090700             DISPLAY "PROBLEMAS COM A ESTACAO"
090800     ELSE
090900     IF      IN-STATUS               =           94  OR  95    OR
091000                                                 97
091100             DISPLAY "DESTINO INVALIDO"
091200     ELSE
091300             DISPLAY " STATUSVALUE  = "          IN-STATUS.
091400
091500
091600     MOVE    1                       TO          OUT-COUNT.
091700     MOVE    0                       TO          OUT-DESTINATION.
091800     MOVE    0                       TO          OUT-STATUS.
091900     MOVE    101                     TO          OUT-TEXT-LENGTH.
092000
092100     SEND    COMS-OUT                FROM        AREA-OUT.
092200
092300     IF      OUT-STATUS              NOT =        0  AND  92
092400             DISPLAY "ERRO NO ENVIO DA MENSAGEM".
092500
092600
092700     MOVE    99                      TO          IN-STATUS.
092800
092900
093000 550-S-ERRO-IN.
093100     EXIT.
