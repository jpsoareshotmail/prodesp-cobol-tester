079700*
079800
079900     MOVE    "N"                     TO      CH-NOTFOUND.
080000
080100
080200     LOCK    NOVAPLACSE2             AT
080300             NPL-CHASSI              EQUAL   IN-CHASSI
080400       ON    EXCEPTION
080500         IF  DMSTATUS(NOTFOUND)
080600             MOVE    "S"             TO      CH-NOTFOUND
080700         ELSE
080800             DISPLAY "PC/GEV/T445/DB - LOCK ERROR NOVAPLACSE2"
080900             PERFORM 600-E-ERRODB    THRU    600-S-ERRODB
081000             CALL    SYSTEM  DMTERMINATE.
081100
081200*
081300 300-S-NOVAPLACA.
081400     EXIT.
081500
081600
086100
086200 500-E-SENDCOMS.
086300
086400     MOVE    0                       TO      OUT-STATUS.
086500     MOVE    1                       TO      OUT-COUNT.
086600
086700     MOVE    IN-FIXA                 TO      OUT-FIXA.
086800
086900     IF      IA1                     =       ZEROS
087000             MOVE    IA1             TO      OUT-RETORNO
087100             MOVE    036             TO      OUT-TEXT-LENGTH
087200     ELSE
087300             MOVE    IA1             TO      OUT-ERRO-RET
087400             MOVE    IN-CHASSI       TO      OUT-ERRO-CHASSI
087500             MOVE    IN-CNPJ         TO      OUT-ERRO-CPF
087600             IF      OUT-TEXT-LENGTH =       101
087700                     MOVE    IN-COD-PAG      TO  OUT-ERRO-COD-PAG
087800                     MOVE    IN-COD-BANCO    TO
087900                                             OUT-ERRO-COD-BANCO
088000                     MOVE    IN-DTA-CONTAB   TO
088100                                             OUT-ERRO-DTA-CONTAB
088200                     MOVE    IN-NSU-PROD     TO
088300                                             OUT-ERRO-NSU-PRODESP.
088400
088500
088600
088700
088800     MOVE    WS-AGENDA-DESG          TO      OUT-AGENDA.
088900     MOVE    IN-STATION              TO      OUT-DESTINATION.
089000
089100     SEND    COMS-OUT                FROM    AREA-OUT.
089200
089300
