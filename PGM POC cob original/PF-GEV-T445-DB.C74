094300     IF      DMSTATUS(NOTFOUND)      DISPLAY "NOTFOUND"      ELSE
094400     IF      DMSTATUS(DUPLICATES)    DISPLAY "DUPLICATES"    ELSE
094500     IF      DMSTATUS(DEADLOCK)      DISPLAY "DEADLOCK"      ELSE
094600     IF      DMSTATUS(KEYCHANGED)    DISPLAY "KEYCHANGED"    ELSE
094700     IF      DMSTATUS(DATAERROR)     DISPLAY "DATAERROR"     ELSE
094800     IF      DMSTATUS(NOTLOCKED)     DISPLAY "NOTLOCKED"     ELSE
094900     IF      DMSTATUS(SYSTEMERROR)   DISPLAY "SYSTEMERROR"   ELSE
095000     IF      DMSTATUS(IOERROR)       DISPLAY "IOERROR"       ELSE
095100     IF      DMSTATUS(LIMITERROR)    DISPLAY "LIMITERROR"    ELSE
095200     IF      DMSTATUS(OPENERROR)     DISPLAY "OPENERROR"     ELSE
095300     IF      DMSTATUS(CLOSEERROR)    DISPLAY "CLOSEERROR"    ELSE
095400     IF      DMSTATUS(NORECORD)      DISPLAY "NORECORD"      ELSE
095500     IF      DMSTATUS(INUSE)         DISPLAY "INUSE"         ELSE
095600     IF      DMSTATUS(AUDITERROR)    DISPLAY "AUDITERROR"    ELSE
