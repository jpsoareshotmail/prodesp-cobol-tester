030100/*********************
030200 PROCEDURE   DIVISION.
030300**********************
030400
030500 MONITORA    SECTION.
030600 000-E-MONITORA.
030700
030800     MOVE    ATTRIBUTE NAME OF ATTRIBUTE EXCEPTIONTASK
030900                            OF ATTRIBUTE EXCEPTIONTASK OF MYSELF
031000                            TO LINKTOCOMS.
031100
031200     CHANGE  ATTRIBUTE TITLE OF "DCILIBRARY" TO LINKTOCOMS.
031300
031400     ENABLE  INPUT  COMS-IN          KEY         "ONLINE"
031500
031600     CALL    "GET_DESIGNATOR_USING_NAME IN DCILIBRARY"
031700                                    USING    WS-AGENDA-OUT,
031800                                    VALUE    AGENDA,
031900                                             WS-AGENDA-DESG
032000                                    GIVING   WS-CALL-ERROR.
032100
032200     OPEN    UPDATE     DB01
032300       ON    EXCEPTION
032400             DISPLAY "GEV/T445 - ERRO OPEN TDBDETRAN"
032500             CALL    SYSTEM  DMTERMINATE.
032600
032700
032800     OPEN    UPDATE     DB02
032900       ON    EXCEPTION
033000             DISPLAY "GEV/T445 - ERRO OPEN TDBTAXAS"
033100             CALL    SYSTEM  DMTERMINATE.
033200
033300
033400     PERFORM 010-E-PROCESSA          THRU    010-S-PROCESSA
033500             UNTIL   IN-STATUS       EQUAL   99.
033600
033700
033800
033900
034000     CLOSE   DB01
034100       ON    EXCEPTION
034200             DISPLAY "GEV/T445 - ERRO CLOSE TDBDETRAN"
034300             CALL    SYSTEM  DMTERMINATE.
034400
034500
034600     CLOSE   DB02
034700       ON    EXCEPTION
034800             DISPLAY "GEV/T445 - ERRO CLOSE TDBTAXAS"
034900             CALL    SYSTEM  DMTERMINATE.
035000
035100
035200 000-S-MONITORA.     STOP RUN.
035300
035400/*****************************************************************
035500*        ROTINA  DE  TRATAMENTO  DAS  TRANSACOES  DO  PROGRAMA   *
035600******************************************************************
035700
035800 010-E-PROCESSA.
035900
036000     MOVE    SPACES                  TO      AREA-IN
036100                                             AREA-OUT.
036200
036300     MOVE    0                       TO      CH-NOTF
036400                                             IA1.
036500
036600
036700     RECEIVE COMS-IN MESSAGE         INTO    AREA-IN.
036800
036900
037000     IF      IN-STATUS               =       0   OR  80  OR
037100                                             89  OR  90  OR
037200                                             91  OR  92  OR
037300                                             93  OR  94  OR  97
037400
037500             NEXT    SENTENCE
037600     ELSE
037700     IF      IN-STATUS               =       99
037800             GO                      TO      010-S-PROCESSA
037900     ELSE
038000             PERFORM 550-E-ERRO-IN   THRU    550-S-ERRO-IN
038100             GO                      TO      010-S-PROCESSA.
038200
038300     IF      IN-CODE                 =       "V445"
038400             PERFORM 020-E-CONSISTE  THRU    020-S-CONSISTE
038500     ELSE
038600             MOVE    239             TO      IA1.
038700
038800
038900     PERFORM 500-E-SENDCOMS          THRU    500-S-SENDCOMS.
039000
039100     FREE    TAXASDS.
039200     FREE    NOVAPLACDS.
039300
039400 010-S-PROCESSA.
039500     EXIT.
039600
039700/*****************************************************************
039800*                   ROTINA DE CONSISTENCIA                       *
039900******************************************************************
040000 020-E-CONSISTE.
040100
040200     MOVE    083                     TO      OUT-TEXT-LENGTH.
040300
040400     IF      IN-CHASSI               EQUAL   SPACES OR ZEROS
040500             MOVE    02              TO      IA1
040600             GO                      TO      020-S-CONSISTE
040700     ELSE
040800             NEXT    SENTENCE.
040900
041000
041100
041200     IF      IN-CNPJX                EQUAL   SPACES OR ZEROS
041500             MOVE    06              TO      IA1
041600             GO                      TO      020-S-CONSISTE
041700
041900     ELSE
042000             NEXT    SENTENCE.
042100
042200
042300     MOVE    SPACES                  TO      WS-PARM1-CPF.
042400     MOVE    IN-CNPJ-CPF             TO      WS-NUMERO-CPF.
042500     MOVE    IN-CNPJ-DIG             TO      WS-DC-CPF.
042600
042700     CALL    "DIGITCPF       OF      PC/LIB/DIGITCHECK"
042800                                     USING   WS-PARM1-CPF
042900                                             WS-PARM2-CPF.
043000
043100     IF      IN-CNPJ-DIG             =       WS-DC-CPF
043200             NEXT    SENTENCE
043300     ELSE
043400             MOVE    SPACES          TO      WS-PARM1-CGC
043500             MOVE    IN-CNPJ         TO      WS-PARM1-CGC
043600
043700             CALL    "DIGITCGC       OF      PC/LIB/DIGITCHECK"
043800                                     USING   WS-PARM1-CGC
043900                                             WS-PARM2-CGC
044000
044100        IF   IN-CNPJ-DIG              =       WS-DC-CGC
044200             NEXT    SENTENCE
044300        ELSE
044400             MOVE    003             TO      IA1
044500             GO                      TO      020-S-CONSISTE.
044600
044700     IF      IN-TIPO-CLIE            NOT =   0 AND 1 AND 2 AND
044800                                             3 AND 4 AND 5
044900             MOVE    483             TO      IA1
045000             GO                      TO      020-S-CONSISTE.
045100
045200     IF      IN-COD-PAG          NOT  =      92
045210             MOVE    009             TO      IA1
045220             GO                      TO      020-S-CONSISTE.
045230
045300 020-10-CONSISTE.
045400
045500
045700     PERFORM 300-E-NOVAPLACA THRU    300-S-NOVAPLACA
045800
045900     IF    CH-NOTFOUND             =       "S"
046000             MOVE    11              TO      IA1
046100             GO                      TO      020-S-CONSISTE
046200     ELSE
046400       IF    NPL-CPF-CGC         NOT EQUAL   IN-CNPJ
046500             MOVE    08              TO      IA1
046600             GO                      TO      020-S-CONSISTE
046700       ELSE
046800       IF    IN-COD-PAG              =       092     AND
046900             NPL-SITUACAO        NOT EQUAL   4
047000             MOVE    11              TO      IA1
047100             GO                      TO      020-S-CONSISTE.
047200
048900
049000
049100     IF      ZEROS                   =       IN-COD-BANCO  AND
049200                                             IN-DTA-CONTAB AND
049300                                             IN-NSU-PROD
049400
049800              MOVE   005      TO      IA1
049900
050100     ELSE
050200
051200             MOVE  101               TO      OUT-TEXT-LENGTH
051300             PERFORM 200-E-TAXAS-2   THRU    200-S-TAXAS-2
051400
051500             IF      CH-NOTFOUND-TAX =       "S"   AND
051600                     OUT-QTD-TAX     =       ZEROS
051700                     MOVE   005      TO      IA1
051800             ELSE
051900
052100                    PERFORM 080-E-ALTERA-NPL   THRU
052200                                     080-S-ALTERA-NPL.
052300
052400
052500
052600
052700
052800
052900
053000 020-S-CONSISTE.
053100     EXIT.
053200
053300
053400/*****************************************************************
053500*              ROTINA DE ATUALIZACAO DO NOVAPLACDS               *
053600******************************************************************
053700
053800 080-E-ALTERA-NPL.
053900
054000     BEGIN-TRANSACTION               NO-AUDIT    PRODRDSDS
054100        ON   EXCEPTION
054200         IF  DMSTATUS (DEADLOCK)     OR
054300             DMSTATUS (ABORT)
054400             WAIT    03
054500             GO                      TO      080-E-ALTERA-NPL
054600         ELSE
054700             DISPLAY "PC/GEV/T445/DB : BEGIN-TRANSACTION ERROR"
054800             PERFORM 600-E-ERRODB    THRU        600-S-ERRODB
054900             CALL    SYSTEM  DMTERMINATE.
055000
055100     MOVE    5                       TO      NPL-SITUACAO.
055200     MOVE    IN-TIPO-CLIE            TO      NPL-ORIGEM.
055300
055400     STORE   NOVAPLACDS
055500         ON  EXCEPTION
055600             DISPLAY "PC/GEV/T445/DB - ERRO STORE NOVAPLACDS"
055700             PERFORM 600-E-ERRODB    THRU        600-S-ERRODB
055800             CALL    SYSTEM  DMTERMINATE.
055900
056000
056100 080-END-TRANS.
056200
056300     END-TRANSACTION                 NO-AUDIT    PRODRDSDS
056400        ON   EXCEPTION
056500         IF  DMSTATUS (ABORT)
056600             GO                      TO          080-E-ALTERA-NPL
056700         ELSE
056800             DISPLAY "PC/GEV/T445/DB - END-TRANSACTION ERROR"
056900             PERFORM 600-E-ERRODB    THRU        600-S-ERRODB
057000             CALL    SYSTEM  DMTERMINATE.
057100
057200
057300 080-S-ALTERA-NPL.
057400     EXIT.
057500
062800
064800 200-E-TAXAS-2.
064900
065000     SET     TAXBCDTPSE1             TO      ENDING.
065100     MOVE    "N"                     TO      CH-NOTFOUND-TAX.
065200     MOVE    ZEROS                   TO      OUT-QTD-TAX.
065300
065400 200-10-TAXAS-2.
065500
065600
065700
065800     LOCK    PRIOR  TAXBCDTPSE1      AT
065900             TAX-COD-BANCO           =       IN-COD-BANCO     AND
066000             TAX-NSU-PROD            =       IN-NSU-PROD      AND
066100             TAX-DT-CONTB            =       IN-DTA-CONTAB
066200       ON    EXCEPTION
066300       IF    DMSTATUS (NOTFOUND)
066400             MOVE    "S"             TO      CH-NOTFOUND-TAX
066500             GO                      TO      200-S-TAXAS-2
066600       ELSE
066700             DISPLAY "PC/GEV/T445/DB: FIND ERROR TAXBCDTPSE1"
066800             PERFORM 600-E-ERRODB    THRU    600-S-ERRODB
066900             CALL    SYSTEM          DMTERMINATE.
067000
067100
067200     IF      TAX-COD-PAG             =       IN-COD-PAG  AND
067300             TAX-SITUACAO            =       ZEROS       AND
067400            (TAX-CPF-CGC             =       IN-CNPJ)
067500
067600
067700             PERFORM 250-E-ALTERA-TAXA
067800                                     THRU   250-S-ALTERA-TAXA
067900
068000             ADD    1                TO      OUT-QTD-TAX
068100     ELSE
068200
068300     GO                              TO      200-10-TAXAS-2.
068400
068500 200-S-TAXAS-2.
068600     EXIT.
068700
068800
073000*
073100 250-E-ALTERA-TAXA.
073200
073300
073400     BEGIN-TRANSACTION            NO-AUDIT   TAXASRDSDS
073500        ON   EXCEPTION
073600             DISPLAY "PC/GEV/T445/DB : BEGIN-TRANSACTION ERROR-1"
073700             PERFORM 600-E-ERRODB    THRU    600-S-ERRODB
073800             CALL    SYSTEM          DMTERMINATE.
073900
074000
074100     DELETE  TAXASDS
074200        ON   EXCEPTION
074300             DISPLAY "PC/GEV/T445/DB : DELETE ERROR TAXASDS"
074400             PERFORM 600-E-ERRODB    THRU    600-S-ERRODB
074500             CALL    SYSTEM          DMTERMINATE.
074600
074700
074800     RECREATE TAXASDS
074900        ON   EXCEPTION
075000             DISPLAY "PC/GEV/T445/DB : RECREATE ERROR TAXASDS"
075100             PERFORM 600-E-ERRODB    THRU    600-S-ERRODB
075200             CALL    SYSTEM          DMTERMINATE.
075300
075400     MOVE    3                       TO      TAX-SITUACAO.
075410
075420     MOVE    NPL-PLACA               TO      TAX-PLACA-MERC
075500
075600     MOVE    "ECRV"                  TO      TAX-USUARIO.
075700     IF      IN-TIPO-CLIE            =       1
075800             MOVE "P. DETRAN "       TO      TAX-USUARIO
075900     ELSE
076000     IF      IN-TIPO-CLIE            =       2
076100             MOVE "P. POUPAT."       TO      TAX-USUARIO
076200     ELSE
076300     IF      IN-TIPO-CLIE            =       3
076400             MOVE "MOBILE    "       TO      TAX-USUARIO
076500     ELSE
076600     IF      IN-TIPO-CLIE            =       4
076700             MOVE "TOTEM     "       TO      TAX-USUARIO
076800     ELSE
076900     IF      IN-TIPO-CLIE            =       5
077000             MOVE "P. DIGITAL"       TO      TAX-USUARIO.
077100
077200     STORE   TAXASDS
077300        ON   EXCEPTION
077400             DISPLAY "PC/GEV/T445/DB : STORE ERROR TAXASDS"
077500             PERFORM 600-E-ERRODB    THRU    600-S-ERRODB
077600             CALL    SYSTEM          DMTERMINATE.
077700
077800
077900
078000     END-TRANSACTION              NO-AUDIT   TAXASRDSDS
078100        ON   EXCEPTION
078200             DISPLAY "PC/GEV/T445/DB : END-TRANSACTION ERROR-1"
078300             PERFORM 600-E-ERRODB    THRU    600-S-ERRODB
078400             CALL    SYSTEM          DMTERMINATE.
078500
078600
078700
078800 250-S-ALTERA-TAXA.
078900     EXIT.
079000
079100
