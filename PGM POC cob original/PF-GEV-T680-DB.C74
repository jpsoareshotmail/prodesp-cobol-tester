066800/
066900*----------------------------------------------------------------*
067000*      DECLARACAO  DA  COMMUNICATION  DESCRIPTION (CD) DO COMS   *
067100*----------------------------------------------------------------*
067200*
067300 COMMUNICATION       SECTION.
067400*-----------------------------
067500*
067600 INPUT HEADER COMS-IN;
067700       PROGRAMDESG            IS   COMS-IN-PROGRAM;
067800       FUNCTIONSTATUS         IS   COMS-IN-FUNCTION-STATUS;
067900       FUNCTIONINDEX          IS   COMS-IN-FUNCTION-INDEX;
068000       USERCODE               IS   COMS-IN-USERCODE;
068100       SECURITYDESG           IS   COMS-IN-SECURITY-DESG;
068200       TRANSPARENT            IS   COMS-IN-TRANSPARENT;
068300       VTFLAG                 IS   COMS-IN-VT-FLAG;
068400       TIMESTAMP              IS   COMS-IN-TIMESTAMP;
068500       STATION                IS   COMS-IN-STATION;
068600       TEXTLENGTH             IS   COMS-IN-TEXT-LENGTH;
068700       STATUSVALUE            IS   COMS-IN-STATUS;
068800       MESSAGECOUNT           IS   COMS-IN-MSG-COUNT;
068900       RESTART                IS   COMS-IN-RST-LOC;
069000       AGENDA                 IS   COMS-IN-AGENDA;
069100       SDFINFO                IS   COMS-IN-INFO.
069200*
069300 OUTPUT HEADER COMS-OUT;
069400       DESTCOUNT              IS   COMS-OUT-COUNT;
069500       TEXTLENGTH             IS   COMS-OUT-TEXT-LENGTH;
069600       STATUSVALUE            IS   COMS-OUT-STATUS;
069700       TRANSPARENT            IS   COMS-OUT-TRANPARENT;
069800       VTFLAG                 IS   COMS-OUT-VT-FLAG;
069900       CONFIRMFLAG            IS   COMS-OUT-CONFIRM-FLAG;
070000       CONFIRMKEY             IS   COMS-OUT-CONFIRMKEY;
070100       DESTINATIONDESG        IS   COMS-OUT-DESTINATION;
070200       NEXTINPUTAGENDA        IS   COMS-OUT-NEXT-INPUT-AG;
070300       CASUALOUTPUT           IS   COMS-OUT-CASUAL-OUTPUT;
070400       SETNEXTINPUTAGENDA     IS   COMS-OUT-SET-NEXT-AG;
070500       RETAINTRANSACTIONMODE  IS   COMS-OUT-RETAIN-TRANMODE;
070600       AGENDA                 IS   COMS-OUT-AGENDA;
070700       SDFINFO                IS   COMS-OUT-INFO.
070800*
070900******************************************************************
071000/
071100 PROCEDURE   DIVISION.
071200**********************
071300
071400******************************************************************
071500*            MODULO      MONITOR     DO      PROGRAMA            *
071600******************************************************************
071700*
071800 000-E-MONITOR.
071900
072000
072100
072200     IF      ATTRIBUTE   RESTARTED   OF     MYSELF
072300                                     EQUAL  VALUE   TRUE
072400             DISPLAY "PC/GEV/T680/DB ====> FIM NORMAL"
072500             GO                      TO     000-S-MONITOR.
072600
072700
072800     PERFORM 010-E-INICIO            THRU   010-S-INICIO.
072900
073000     PERFORM 020-E-PROCESSA          THRU   020-S-PROCESSA
073100             UNTIL   COMS-IN-STATUS  =      99.
073200
073300     PERFORM 230-E-FINAL             THRU   230-S-FINAL.
073400
073500
073600
073700 000-S-MONITOR.
073800     STOP    RUN.
073900
074000/
074100******************************************************************
074200*            MODULO      INICIAL      DO      PROGRAMA           *
074300******************************************************************
074400*
074500 010-E-INICIO.
074600
074700
074800
074900     MOVE    ATTRIBUTE NAME OF ATTRIBUTE EXCEPTIONTASK
075000                            OF ATTRIBUTE EXCEPTIONTASK OF MYSELF
075100                            TO LINKTOCOMS.
075200
075300     CHANGE  ATTRIBUTE TITLE OF "DCILIBRARY" TO LINKTOCOMS.
075400
075500     ENABLE  INPUT COMS-IN KEY "ONLINE".
075600
075700     ENABLE  INPUT COMS-IN         KEY     "ONLINE"
075800
075900     CALL    "GET_DESIGNATOR_USING_NAME  IN  DCILIBRARY"
076000                                     USING   AX-AGENDA-NAME,
076100                                     VALUE   AGENDA,
076200                                             AX-AGENDA-DESG
076300                                     GIVING  AX-CALL-ERROR.
076400
076500
076600
076700     OPEN    UPDATE      DB01
076800       ON    EXCEPTION
076900             DISPLAY "PC/GEV/T680/DB : OPEN ERROR DBDETRAN"
077000             PERFORM 220-E-ERRODB    THRU    220-S-ERRODB
077100             CALL    SYSTEM          DMTERMINATE.
077200
077300
077400     OPEN    INQUIRY     DB02
077500       ON    EXCEPTION
077600             DISPLAY "PC/GEV/T680/DB : OPEN ERROR DBGEVER"
077700             PERFORM 220-E-ERRODB    THRU    220-S-ERRODB
077800             CALL    SYSTEM          DMTERMINATE.
077900
078000
078100     OPEN    INQUIRY     DB03
078200       ON    EXCEPTION
078300             DISPLAY "PC/GEV/T680/DB : OPEN ERROR TTABELAS"
078400             PERFORM 220-E-ERRODB    THRU    220-S-ERRODB
078500             CALL    SYSTEM          DMTERMINATE.
078600
078700
078800
078900 010-S-INICIO.
079000     EXIT.
079100
