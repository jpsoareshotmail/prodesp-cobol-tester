102800******************************************************************
102900*
103000 060-E-PLA-PER.
103100
103200
103300
103400     PERFORM 120-E-PLACSS6           THRU    120-S-PLACSS6.
103500
103600     IF      CH-NF-NOV               =       "N"
103700      IF     NPL-SITUACAO            =       04
103800             MOVE    19              TO      IA1
103900             GO                      TO      060-S-PLA-PER
104000      ELSE
104100             MOVE    NPL-LETRA       TO      TBB-LETRA(1)
104200             MOVE    NPL-NUMERO      TO      TBB-NUMER(1)
104300             MOVE    NPL-FINAL       TO      TBB-FINAL(1)
104400             MOVE    NPL-SITUACAO    TO      TBB-SIT  (1)
104500             MOVE    "S"             TO      CH-CHASSI.
104600
104700
104800 060-S-PLA-PER.
104900     EXIT.
