178000 190-E-ALTERA-PLACA.
178100
178200     MOVE    NPL-PLACA               TO     AX-PLACA.
178300
178400     SET     IN1                     TO      1.
178500
178600     MOVE    AX-ALFA                 TO     AX-ALFA-ALTER.
178700
178800
178900     IF      AX-ALFA                 IS     ALPHABETIC
179000             NEXT SENTENCE
179100     ELSE
179200             SEARCH  TBA-LET-NUM     AT     END
179300                     MOVE   "N"      TO     AX-ALTEROU
179400             WHEN    TBA-NUM (IN1)   =      AX-ALFA
179500                     MOVE  TBA-LET (IN1)    TO  AX-ALFA-ALTER
179600                     MOVE   "S"      TO     AX-ALTEROU.
179700
179800*     IF      AX-ALFA                 IS     ALPHABETIC
179900*             SEARCH  TBA-LET-NUM     AT     END
180000*                     MOVE   "N"      TO     AX-ALTEROU
180100*             WHEN    TBA-LET (IN1)   =      AX-ALFA
180200*                   MOVE    TBA-NUM (IN1)    TO  AX-ALFA-ALTER
180300*                   MOVE   "S"        TO     AX-ALTEROU.
