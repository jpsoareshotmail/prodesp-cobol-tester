167700 160-E-TABINTDS.
167800
167900     MOVE    "N"                     TO      CH-NOTFOUND.
168000
168100     FIND    TABINTSE                AT
168200             TAB-INTIPO              =       CH-INTIPO AND
168300             TAB-INCHAVE             =       CH-INCHAVE
168400       ON    EXCEPTION
168500        IF   DMSTATUS (NOTFOUND)
168600             MOVE    "S"             TO      CH-NOTFOUND
168700             IF     CH-INTIPO        =      3
168800                    MOVE  SPACES     TO     TAB-IN-COR
168900             ELSE
169000                    MOVE  SPACES     TO     TAB-IN-CATEGORIA
169100
169200        ELSE
169300             DISPLAY "PC/GEV/T680/DB : FIND ERROR TABINTSE"
169400             PERFORM 220-E-ERRODB    THRU    220-S-ERRODB
169500             CALL    SYSTEM          DMTERMINATE.
169600
169700
169800 160-S-TABINTDS.
169900     EXIT.
