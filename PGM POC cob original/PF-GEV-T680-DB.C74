084600*            TRATA TRANSACAO V680                                *
084700******************************************************************
084800*
084900 030-E-V680.
085000
085100
085200
085300     MOVE    ZEROS                   TO     IA1.
085400     MOVE    SPACES                  TO     CH-ATUALIZ
085500                                            AX-ALTEROU.
085600     MOVE    "N"                     TO     CH-CHASSI.
085700
085800
085900     PERFORM 040-E-CONSISTE          THRU   040-S-CONSISTE.
086000
086100      IF      IA1                    >     0
086200              GO                     TO    030-10-ENVIA.
086300
086400
086500
086600*  -->  Chassi encontrado
086700     IF      CH-CHASSI               =      "S"
086800             MOVE    "G"             TO     CH-ATUALIZ
086900             GO                      TO     030-10-ENVIA
087000     ELSE
087100             NEXT    SENTENCE.
087200
087300*  --->  Aloca e atualiza a placa no Dataset
087400     PERFORM 100-E-PLACA-SORT        THRU   100-S-PLACA-SORT.
087500
087600
087700 030-10-ENVIA.
087800
087900     PERFORM 140-E-ENVIA-OUT         THRU   140-S-ENVIA-OUT.
088000
088100
088200
088300 030-S-V680.
088400     EXIT.
088500
088600/
088700******************************************************************
088800*            CONSISTE STRING DE ENTRADA                          *
088900******************************************************************
089000*
089100 040-E-CONSISTE.
089200
089300
089400     IF      IN-CHASSI               =      SPACES
089500             MOVE    006             TO     IA1
089600             GO                      040-S-CONSISTE.
089700
089800
089900
090000     IF      IN-CPF-CGC-X            IS     NUMERIC   AND
090100             IN-CPF-CGC              >      0
090200             NEXT    SENTENCE
090300     ELSE
090400             MOVE    007             TO     IA1
090500             GO                      040-S-CONSISTE.
090600
090700** Verifica se eh CGC
090800** para digito CPF deve-se mandar calcular ..pois CPF com digito
090900*  igual a zeros .. a LIB retorna como erro
091000*
091100     MOVE    "V"                     TO     AX-COD-CGC.
091200     MOVE    IN-CPF-CGC              TO     AX-PARM1-CGC-R.
091300     MOVE    12                      TO     AX-TAM-CGC.
091400     CALL    "DIGITCGC       OF      PC/LIB/DIGITCHECK"
091500                                     USING  AX-PARM1-CGC
091600                                            AX-PARM2-CGC.
091700     IF      AX-CONS-CGC             =      1
091800** eh CGC
091900             NEXT   SENTENCE
092000     ELSE
092100             MOVE    IN-CPF-CGC      TO     AX-CPF
092200             MOVE    AX-NUM-CPF      TO     AX-NUMERO-CPF
092300             CALL    "DIGITCPF       OF     PC/LIB/DIGITCHECK"
092400                                     USING  AX-PARM1-CPF
092500                                            AX-PARM2-CPF
092600
092700             IF      AX-DC-CPF        =     AX-DIG-CPF
092800** eh CPF
092900                     NEXT   SENTENCE
093000             ELSE
093100                     MOVE    008     TO     IA1
093200                     GO              040-S-CONSISTE.
093300
093400
093500     PERFORM 080-E-BIN               THRU   080-S-BIN.
093600
093700     IF      IA1                     >      0
093800             GO                      040-S-CONSISTE.
093900
094000
094100*  ---> Limpa tabela
094200
094300     MOVE    SPACES                  TO      TBB-PLACAS.
094400
094500
094600*  ---> Verifica Servicos Pendentes
094700
094800     PERFORM 050-E-SERV-PEN          THRU    050-S-SERV-PEN.
094900
095000     IF      IA1                     >       0
095100             GO                      TO      040-S-CONSISTE.
095200
095300
095400
095500
095600*  ---> Verifica Placa Personalizada  e Altera p/ LETRA
095700
095800     SET     NOVAPLACSS6             TO      BEGINNING.
095900
096000     PERFORM 060-E-PLA-PER           THRU    060-S-PLA-PER.
096100
096200     IF      IA1                     >       0  OR
096300             CH-CHASSI               =       "S"
096400             GO                      TO      040-S-CONSISTE.
096500
096600
096700
096800
096900*  --->  Sorteios Anteriores
097000*  --->  Le as vinte placas sorteadas  e Altera p/ LETRA
097100
097200     MOVE    "N"                     TO      CH-NF-NOV.
097300     MOVE    SPACES                  TO      AX-ALTEROU.
097400     SET     NOVAPLACSS5             TO      BEGINNING.
097500     MOVE    ZEROS                   TO      IX1.
097600     PERFORM 070-E-PLACSOR           THRU    070-S-PLACSOR
097700             VARYING IX1             FROM    1 BY  1
097800             UNTIL   IX1             >       20  OR
097900                     CH-NF-NOV       =       "S" OR
098000                     IA1             >      ZEROS.
098100
098200
098300     IF      CH-CHASSI               =       "S"     OR
098400             IA1                     >      ZEROS
098500*  --> Placas ja estao selecionadas
098600             GO                      TO      040-S-CONSISTE.
098700
098800
098900
099000
099100
099200 040-S-CONSISTE.
099300     EXIT.
099400
099500/
099600******************************************************************
099700*            VERIFICA  SERVICOS PENDENTES                        *
099800******************************************************************
099900*
100000 050-E-SERV-PEN.
100100
100200
100300
100400     MOVE    "N"                     TO      CH-NF-PEN.
100500
100600     FIND    GERCHASSISE             AT
100700             GER-CHASSI              =       IN-CHASSI
100800       ON    EXCEPTION
100900        IF   DMSTATUS (NOTFOUND)
101000             MOVE    "S"             TO      CH-NF-PEN
101100             GO                      TO      050-S-SERV-PEN
101200        ELSE
101300             DISPLAY "PC/GEV/T680/DB: FIND ERROR GERCHASSISE"
101400             PERFORM 220-E-ERRODB    THRU    220-S-ERRODB
101500             CALL    SYSTEM          DMTERMINATE.
101600
101700
101800     MOVE    17                      TO      IA1.
101900
102000
102100
102200 050-S-SERV-PEN.
102300     EXIT.
