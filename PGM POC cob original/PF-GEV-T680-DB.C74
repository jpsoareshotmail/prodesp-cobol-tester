079300******************************************************************
079400*            MODULO    DE    TRATAMENTO    DE    TRANSACOES      *
079500******************************************************************
079600*
079700 020-E-PROCESSA.
079800
079900
080000
080100     MOVE    SPACES                  TO     AREA-IN
080200                                            AREA-OUT.
080300
080400     RECEIVE COMS-IN MESSAGE         INTO   AREA-IN.
080500
080600     IF      COMS-IN-STATUS          =      00 OR 92 OR 93 OR
080700                                            97 OR 89
080800             NEXT    SENTENCE
080900     ELSE
081000     IF      COMS-IN-STATUS          =      99
081100             GO                      TO     020-S-PROCESSA
081200     ELSE
081300             PERFORM 210-E-ERROCOMS  THRU   210-S-ERROCOMS
081400             GO                      TO     020-S-PROCESSA.
081500
081600
081700     ACCEPT  AX-DATE-4AMMDD          FROM   DATE  YYYYMMDD.
081800     ACCEPT  AX-TIME                 FROM   TIME.
081900
082000     MOVE    ZEROS                   TO     IA1.
082100
082200      IF     IN-CODE                 =      "V680"
082300             PERFORM 030-E-V680      THRU   030-S-V680
082400      ELSE
082500             MOVE    001             TO     IA1
082600             MOVE    IN-CPF-CGC-X    TO     OUT-CPF-CGC-X
082700             MOVE    IN-CHASSI       TO     OUT-CHASSI.
082800
082900
083000
083100 020-10-MSG.
083200
083300
083400     PERFORM 180-E-MSGOUT            THRU   180-S-MSGOUT.
083500
083600
083700     FREE    NOVAPLACDS.
083800
083900
084000
084100 020-S-PROCESSA.
084200     EXIT.
