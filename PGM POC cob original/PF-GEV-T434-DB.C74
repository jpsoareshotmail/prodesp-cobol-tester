050096         DISPLAY "PC/GE/T434/DB - PLACA           : " NPL-PLACA
050098         DISPLAY "PC/GE/T434/DB - SIT PLACA       : " NPL-SITUACAO
050100                 MOVE   469              TO      IA1
050110                 PERFORM 200-E-ENV-ERRO  THRU    200-S-ENV-ERRO
050120                 GO                      TO      080-S-RECREAR.
050130
050140
050200     BEGIN-TRANSACTION            NO-AUDIT   PRODRDSDS
050300       ON   EXCEPTION
050400        IF  DMSTATUS (DEADLOCK)      OR
050500            DMSTATUS (ABORT)
050600            WAIT    03
050700            GO                       TO      080-E-RECREAR
050800        ELSE
050900            DISPLAY "PC/GEV/T434/DB : BEGIN-TRANS ERROR-080"
051000            PERFORM 260-E-ERRODB     THRU    260-S-ERRODB
051100            CALL    SYSTEM           DMTERMINATE.
051200
051300        PERFORM  130-E-RECR-REG      THRU    130-S-RECR-REG.
051400
051500        STORE NOVAPLACDS
051600          ON EXCEPTION
051700             DISPLAY "PC/GEV/T434/DB : STORE ERROR NOVAPLACDS"
051800             PERFORM 260-E-ERRODB    THRU    260-S-ERRODB
051900             CALL    SYSTEM          DMTERMINATE.
052000
052020     IF      CH-EAU                  =       1
052040             PERFORM 170-E-ATU-EAU   THRU    170-S-ATU-EAU
052060     ELSE
052080             NEXT    SENTENCE.
052100
052200     END-TRANSACTION              NO-AUDIT   PRODRDSDS
052300        ON  EXCEPTION
052400        IF  DMSTATUS (ABORT)
052500            GO                       TO      080-E-RECREAR
052600        ELSE
