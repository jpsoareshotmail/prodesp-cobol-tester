050000
050020*  -->  Verifica existencia no TAXAS/ECRVAUTENTICADS
050040
050070
050080     IF  NPL-SITUACAO                    =       5
050082         PERFORM 160-E-TAXAS-LOCK        THRU    160-S-TAXAS-LOCK
050084         IF  CH-TAX                      =       0
050086             PERFORM 140-E-ECRV-AUT      THRU    140-S-ECRV-AUT
050090             IF  CH-EAU                  =       0
050092         DISPLAY "PC/GE/T434/DB - ERRO NA LIBERACAO TAXA/PLACA"
