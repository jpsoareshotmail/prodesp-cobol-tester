050400/
050500*----------------------------------------------------------------*
050600*      ROTINA  DE  PESQUISA  COM  CHASSI E CPF/CNPJ              *
050700*----------------------------------------------------------------*
050800*
050900 050-E-T444.
051000*
051100
051200     MOVE    SPACES                   TO      WS-CHASSI.
051300     MOVE    ZEROS                    TO      WS-CPFCNPJ.
051400
051500     MOVE    0                        TO      IA1 OUT-RETORNO.
051600
051700
051800     IF      IN-CHASSI                =       SPACES  OR  ZEROS
051900             MOVE   002               TO      IA1
052000             PERFORM 200-E-ENV-ERRO   THRU    200-S-ENV-ERRO
052100             GO                       TO      050-S-T444.
052200
052300     IF      IN-CPFCNPJ               =       ZEROS  OR  SPACES
052400             MOVE   027               TO      IA1
052500             PERFORM 200-E-ENV-ERRO   THRU    200-S-ENV-ERRO
052600             GO                       TO      050-S-T444.
052700
052800     IF      IN-TIPO-CLIE            >       5
052900             MOVE  483               TO      IA1
053000             PERFORM 200-E-ENV-ERRO   THRU    200-S-ENV-ERRO
053100             GO                       TO      050-S-T444.
053200
053300
053400
053500     SET     NOVAPLACDS               TO      BEGINNING.
053600
053700     PERFORM 100-E-LOCK-NVPLAC        THRU    100-S-LOCK-NVPLAC.
053800
053900
054000     IF      CH-NOTFOUND              =       "S"
054100             MOVE    360              TO      IA1
054200             PERFORM 200-E-ENV-ERRO   THRU    200-S-ENV-ERRO
054300             GO                       TO      050-S-T444
054400     ELSE
054500             PERFORM 080-E-RECREAR    THRU    080-S-RECREAR.
054600
054700
054800*
054900 050-S-T444.
055000     EXIT.
055100*
055200/
055300*----------------------------------------------------------------*
055400*    ALTERAR REGISTRO NO PRODPLACDS                              *
055500*----------------------------------------------------------------*
055600*
055700 080-E-RECREAR.
055800*
055900*    GERAR SEQUENCIA ALEATORIA
056000
056100     MOVE    1                   TO      AI1.
056200
056300     PERFORM 120-E-SORTEAR       THRU    120-S-SORTEAR
056400                                 UNTIL   AI1 = 4.
056500
056600
056700*  -->  Verifica existencia no TAXAS/ECRVAUTENTICADS
056800
056900
057000     IF  NPL-SITUACAO                    =       5
057100         PERFORM 160-E-TAXAS-LOCK        THRU    160-S-TAXAS-LOCK
057200         IF  CH-TAX                      =       0
057300             PERFORM 140-E-ECRV-AUT      THRU    140-S-ECRV-AUT
057400             IF  CH-EAU                  =       0
057500         DISPLAY "PC/GE/T444/DB - ERRO NA LIBERACAO TAXA/PLACA"
057600         DISPLAY "PC/GE/T444/DB - CHASSI PESQUISA : " IN-CHASSI
057700         DISPLAY "PC/GE/T444/DB - PLACA           : " NPL-PLACA
057800         DISPLAY "PC/GE/T444/DB - SIT PLACA       : " NPL-SITUACAO
057900                 MOVE   468              TO      IA1
058000                 PERFORM 200-E-ENV-ERRO  THRU    200-S-ENV-ERRO
058100                 GO                      TO      080-S-RECREAR.
058200
058300
058400     BEGIN-TRANSACTION            NO-AUDIT   PRODRDSDS
058500       ON   EXCEPTION
058600        IF  DMSTATUS (DEADLOCK)      OR
058700            DMSTATUS (ABORT)
058800            WAIT    03
058900            GO                       TO      080-E-RECREAR
059000        ELSE
059100            DISPLAY "PC/GEV/T444/DB : BEGIN-TRANS ERROR-080"
059200            PERFORM 260-E-ERRODB     THRU    260-S-ERRODB
059300            CALL    SYSTEM           DMTERMINATE.
059400
059500        PERFORM  130-E-RECR-REG      THRU    130-S-RECR-REG.
059600
059700        STORE NOVAPLACDS
059800          ON EXCEPTION
059900             DISPLAY "PC/GEV/T444/DB : STORE ERROR NOVAPLACDS"
060000             PERFORM 260-E-ERRODB    THRU    260-S-ERRODB
060100             CALL    SYSTEM          DMTERMINATE.
060200
060300     IF      CH-EAU                  =       1
060400             PERFORM 170-E-ATU-EAU   THRU    170-S-ATU-EAU
060500     ELSE
060600             NEXT    SENTENCE.
060700
060800     END-TRANSACTION              NO-AUDIT   PRODRDSDS
060900        ON  EXCEPTION
061000        IF  DMSTATUS (ABORT)
