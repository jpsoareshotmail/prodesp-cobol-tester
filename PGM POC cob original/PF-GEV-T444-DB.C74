035900 MONITORA    SECTION.
036000
036100*
036200 000-E-MONITORA.
036300*
036400
036500     IF     ATTRIBUTE RESTARTED OF MYSELF  =  VALUE TRUE
036600            DISPLAY "PC/GEV/T444/DB : TERMINO ANORMAL"
036700            MOVE    997             TO      IA1
036800            PERFORM 200-E-ENV-ERRO  THRU    200-S-ENV-ERRO
036900            GO                      TO      000-S-MONITORA.
037000
037100
037200     PERFORM 010-E-INICIO           THRU    010-S-INICIO.
037300
037400     PERFORM 030-E-PROCESSA         THRU    030-S-PROCESSA
037500                                    UNTIL
037600             COMS-IN-STATUS          =       99.
037700
037800     PERFORM 900-E-FINAL             THRU    900-S-FINAL.
037900
038000*
038100 000-S-MONITORA.
038200
038300     STOP    RUN.
038400
038500*
038600 010-E-INICIO.
038700*
038800     MOVE    ATTRIBUTE NAME OF ATTRIBUTE EXCEPTIONTASK
038900                            OF ATTRIBUTE EXCEPTIONTASK OF MYSELF
039000                            TO LINKTOCOMS.
039100
039200
039300     CHANGE  ATTRIBUTE TITLE OF "DCILIBRARY" TO LINKTOCOMS.
039400
039500
039600
039700     ENABLE  INPUT  COMS-IN          KEY     "ONLINE"
039800
039900     CALL    "GET_DESIGNATOR_USING_NAME IN DCILIBRARY"
040000                                    USING    AX-AGENDA-OUT,
040100                                    VALUE    AGENDA,
040200                                             AX-AGENDA-DESG
040300                                    GIVING   AX-CALL-ERROR.
040400
040500
040600
