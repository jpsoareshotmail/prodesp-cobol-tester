063100 100-E-LOCK-NVPLAC.
063200*
063300
063400     MOVE    "N"                     TO      CH-NOTFOUND.
063500
063600
063700     LOCK    NOVAPLACSS6    AT
063800             NPL-CHASSI              =       IN-CHASSI
063900       ON    EXCEPTION
064000         IF  DMSTATUS(NOTFOUND)
064100             MOVE    "S"             TO      CH-NOTFOUND
064200             GO                      TO      100-S-LOCK-NVPLAC
064300         ELSE
064400             DISPLAY "PC/GEV/T444/DB - LOCK NOVAPLACDS ERROR"
