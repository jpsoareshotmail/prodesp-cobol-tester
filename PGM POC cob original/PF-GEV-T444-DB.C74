042500/
042600*----------------------------------------------------------------*
042700*        ROTINA  DE  TRATAMENTO  DAS  TRANSACOES  DO  PROGRAMA   *
042800*----------------------------------------------------------------*
042900*
043000 030-E-PROCESSA.
043100*
043200
043300     MOVE    0                       TO      IA1.
043400     MOVE    SPACES                  TO      AREA-IN
043500                                             AREA-OUT.
043600
043700
043800     RECEIVE COMS-IN MESSAGE         INTO    AREA-IN.
043900
044000
044100     IF      COMS-IN-STATUS          =       00 OR 89 OR 92 OR
044200                                             93 OR 97
044300             NEXT    SENTENCE
044400     ELSE
044500     IF      COMS-IN-STATUS          =       99
044600             GO                      TO      030-S-PROCESSA
044700     ELSE
044800             PERFORM 250-E-ERRO-COMS THRU    250-S-ERRO-COMS
044900             GO                      TO      030-S-PROCESSA.
045000
045100     MOVE    COMS-IN-USERCODE        TO      USER-DESG.
045200
045300     CALL    "GET_NAME_USING_DESIGNATOR  OF  DCILIBRARY"
045400                                USING   USER-DESG
045500                                        USER-NAME
045600                                GIVING  USER-FLAG.
045700
045800     ACCEPT  AX-HORA-TIME            FROM    TIME.
045900     ACCEPT  AX-NUMDATE              FROM    DATE.
046000     MOVE    AX-NUMDT-DIA            TO      AX-PROC-DIA.
046100     MOVE    AX-NUMDT-MES            TO      AX-PROC-MES.
046200     MOVE    AX-NUMDT-ANO            TO      AX-PROC-ANO.
046300
046400     MOVE    IN-FIXA                 TO      OUT-FIXA.
046500     MOVE    000                     TO      OUT-RETORNO.
046600
046700     MOVE    ZEROS                   TO      CH-EAU
046800                                             CH-TAX.
046900
047000     IF      IN-CODE                 =       "V444"
047100             PERFORM 050-E-T444      THRU    050-S-T444
047200     ELSE
047300             MOVE    999             TO      IA1
047400             PERFORM 200-E-ENV-ERRO  THRU    200-S-ENV-ERRO.
047500
047600
047700     MOVE    COMS-IN-STATION         TO      COMS-OUT-DESTINATION.
047800     MOVE    AX-AGENDA-DESG          TO      COMS-OUT-AGENDA.
047900
048000     MOVE    1                       TO      COMS-OUT-COUNT.
048100     MOVE    0                       TO      COMS-OUT-STATUS.
048200
048300     IF      IA1                     =       ZEROS
048400             MOVE   ZEROS            TO      OUT-RETORNO
048500             MOVE    070             TO      COMS-OUT-TEXT-LENGTH
048600     ELSE
048700             MOVE    070             TO      COMS-OUT-TEXT-LENGTH
048800             MOVE   IA1              TO      OUT-RETORNO.
048900
049000     SEND    COMS-OUT                FROM    AREA-OUT.
049100
049200*
049300 030-1-PROCESSO.
