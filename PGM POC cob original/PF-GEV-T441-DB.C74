061800                                             AX-LETRA.
061900
062000     MOVE    ZEROS                   TO      AX-CPF-CNPJ
062100                                             AX-RENAVAM
062200                                             AX-DB-NUMERO
062300                                             AX-NUMERO.
062400
062500*
062600*==>  VERIFICA SE CHASSI PREENCHIDO
062700
062800     IF      (IN-CHASSI              =       SPACES     OR
062900                                             ZEROS      OR
063000                                             LOW-VALUES )
063100             MOVE    001             TO      IA1
063200             GO                      TO      040-S-VERIF-IN.
063300
063400
063500*==>  VERIFICAR DIGITO CHECK DE CPF/CNPJ  PROPRIETARIO
063600
063700     IF      IN-CNPJ-PROP-X          =       ZEROS      OR
063800                                             SPACES     OR
063900                                             LOW-VALUES
064000             MOVE    001             TO      IA1
064100             GO                      TO      040-S-VERIF-IN.
064200
064300
064400* Devido a existencia do CNPJ 00010564000105 consistir se Eh CPF
064500**** Em caso de erro consistir se Eh CNPJ
064600
064700     MOVE    IN-CNPJ-PROP            TO      AX-CPF-CNPJ.
064800     MOVE    ZEROS                   TO      AX-LIB-DC-CPF.
064900*
065000
065100     MOVE    AX-CPF-NUM      TO      AX-LIB-CPF-NUM
065200     MOVE    AX-CPF-DIG      TO      AX-LIB-CPF-DIG
065300     MOVE    SPACES          TO      AX-LIB-DC-CONS
065400     MOVE    09              TO      AX-LIB-DC-TAM
065500     CALL    "DIGITCPF       OF      PC/LIB/DIGITCHECK"
065600                             USING   AX-LIB-DC-CPF
065700                                     AX-LIB-DC-PARM
065800
065900     IF      AX-LIB-DC-CONS          NOT =   1
066000*
066100*
066200             MOVE  ZEROS             TO      AX-LIB-DC-CNPJ
066300             MOVE  AX-CNPJ-NUM       TO      AX-LIB-CNPJ-NUM
066400             MOVE  AX-CNPJ-DIG       TO      AX-LIB-CNPJ-DIG
066500             MOVE  SPACES            TO      AX-LIB-DC-CONS
066600             MOVE  12                TO      AX-LIB-DC-TAM
066700             CALL  "DIGITCGC         OF      PC/LIB/DIGITCHECK"
066800                                     USING   AX-LIB-DC-CNPJ
066900                                             AX-LIB-DC-PARM.
067000             IF    AX-LIB-DC-CONS    NOT =   1
067100                   MOVE  001         TO      IA1
067200                   GO                TO      040-S-VERIF-IN.
067300
067400
