084300                                             101 OR  102
084400             DISPLAY "PROBLEMAS COM A ESTACAO"
084500     ELSE
084600     IF      COMS-IN-STATUS          =       94  OR  95  OR  97
084700             DISPLAY "DESTINO INVALIDO"
084800     ELSE
084900     IF      COMS-IN-STATUS          =       89
085000             DISPLAY "O TAMANHO DE STRING MAIOR QUE INFORMADO"
085100             DISPLAY "TEXTLENGTH = "  COMS-IN-TEXT-LENGTH
085200             DISPLAY "IN-FIXA="  IN-FIXA
085300             DISPLAY "IN-VAR=" IN-VAR
085400             DISPLAY "STATION = "  COMS-IN-STATION
085500             DISPLAY "PROGRAMDESG = "  COMS-IN-PROGRAM
085600             DISPLAY "AGENDA = "  COMS-IN-AGENDA
085700             DISPLAY "TIMESTAMP = "  COMS-IN-TIMESTAMP
085800     ELSE
085900             DISPLAY "STATUSVALUE = "  COMS-IN-STATUS.
086000
086100
086200     MOVE    1                       TO      COMS-OUT-COUNT.
086300     MOVE    0                       TO      COMS-OUT-DESTINATION.
086400     MOVE    0                       TO      COMS-OUT-STATUS.
086500     MOVE    059                     TO      COMS-OUT-TEXT-LENGTH.
086600
086700     MOVE    IN-FIXA                 TO      OUT-FIXA.
086800     MOVE    998                     TO      OUT-RETORNO.
086900
087000
087100
