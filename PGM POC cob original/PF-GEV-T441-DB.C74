075900*      PESQUISA O ULTIMO REGISTRO EM ESCPLACSE1 POR CHASSI       *
076000******************************************************************
076100*
076200 100-E-LASTPLAC.
076300
076400
076500
076600     MOVE    "N"                     TO      CH-NOTFOUND.
076700
076800     FIND    LAST   ESCPLACSE1       AT
076900             EPC-CHASSI              =       IN-CHASSI
077000       ON    EXCEPTION
077100        IF   DMSTATUS (NOTFOUND)
077200             MOVE    "S"             TO      CH-NOTFOUND
077300             MOVE    SPACES          TO      OUT-PLACA
077400             MOVE    ZEROS           TO      OUT-NRO-TENTATIVA
077500             GO                      100-S-LASTPLAC
077600        ELSE
077700             DISPLAY "PC/GEV/T441/DB: FIND ERROR LAST ESCPLACSE1"
077800             PERFORM 140-E-ERRODB    THRU    140-S-ERRODB
077900             CALL    SYSTEM          DMTERMINATE.
078000
078100
078200     MOVE    EPC-LETRAS              TO      OUT-LETRA.
078300     MOVE    EPC-NUMEROS             TO      OUT-NUMEROS.
078400     MOVE    EPC-NR-ORDEM            TO      OUT-NRO-TENTATIVA.
078500
078600
078700
078800 100-S-LASTPLAC.
078900     EXIT.
