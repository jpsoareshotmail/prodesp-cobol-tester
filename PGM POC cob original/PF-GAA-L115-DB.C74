014800/----------------------------------------------------------------*
014900*    P E S Q U I S A   - OBITO                                   *
015000*----------------------------------------------------------------*
015100*
015200
015300 010-E-FIND-OBITO.
015400*
015500
015600
015700     FIND    KEY OF  LAST  OBICPFSE  AT
015800             OBI-CPF                 =       CH-CPF
015900       ON    EXCEPTION
016000        IF   DMSTATUS(NOTFOUND)
016100             MOVE    0               TO      AX-RL115-RET
016200             MOVE    0               TO      AX-RL115-CPF
016300             GO                      TO      010-S-FIND-OBITO
016400        ELSE
016500             DISPLAY "PC/GAA/L115/DB - FIND ERROR OBICPFSE"
016600             CALL                    SYSTEM  DMTERMINATE.
016700
016800
016900
017000     MOVE    1                       TO      AX-RL115-RET.
017100     MOVE    OBI-CPF                 TO      AX-RL115-CPF.
017200
017300
017400 010-S-FIND-OBITO.
017500     EXIT.
017600
