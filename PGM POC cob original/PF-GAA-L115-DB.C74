010700*----------------------------------------------------------------*
010800*    ROTINA PRINCIPAL DO PROGRAMA                                *
010900*----------------------------------------------------------------*
011000*
011100
011200
011300 000-E-PROCEDURE.
011400*
011500
011600
011700     IF      CH-BCO                  =       "S"
011800             GO                      TO      000-05.
011900
012000
012100     OPEN    INQUIRY DB01
012200       ON    EXCEPTION
012300             DISPLAY "PC/GAA/L115/DB - ERRO ABERTURA TDBBLOQUEIOS"
012400             CALL    SYSTEM  DMTERMINATE.
012500
012600
012700     MOVE    "S"                     TO      CH-BCO.
012800
012900
013000 000-05.
013100
013200
013300     MOVE    0                       TO      AX-RL115-CPF.
013400     MOVE    0                       TO      AX-RL115-RET.
013500
013600     MOVE    AX-EL115-CPF            TO      CH-CPF.
013700
013800
013900     PERFORM 010-E-FIND-OBITO        THRU    010-S-FIND-OBITO.
014000
014100
014200
014300 000-S-EXIT.
014400     EXIT PROGRAM.
014500
014600
