055700     IF      AX-GAA-RET-DS           =       "Q"
055800       IF    QXA-DT-QUEIXA           >       ALE-DT-ALERTA   OR
055900            ((QXA-DT-QUEIXA          =       ALE-DT-ALERTA) AND
056000            (QXA-HR-QUEIXA           >       ALE-HR-ALERTA))
056100             GO                      TO      010-S-FIND-PLAS
056200       ELSE
056300             NEXT    SENTENCE
056400     ELSE
056500     IF      AX-GAA-RET-DS           =       "R"
056600       IF    REC-DT-RECUP            >       ALE-DT-ALERTA   OR
056700            ((REC-DT-RECUP           =       ALE-DT-ALERTA) AND
056800            (REC-HR-RECUP            >       ALE-HR-ALERTA))
056900             GO                      TO      010-S-FIND-PLAS
057000       ELSE
057100             NEXT    SENTENCE
057200     ELSE
057300             NEXT    SENTENCE.
057400
057500
057600     MOVE    88                      TO      AX-GAA-RET.
057700     MOVE    "A"                     TO      AX-GAA-RET-DS.
057800     MOVE    ALERTADS                TO      AX-GAA-QUEIXA.
057900
058000
058100 010-S-FIND-PLAS.
058200     EXIT.
058300/
058400******************************************************************
058500*    PESQUISA POR CHASSI NO QUEIXADS E NO RECUPERADODS           *
058600******************************************************************
058700
058800 020-E-FIND-CHAS.
058900
059000     FIND   KEY OF   QXACHASS        AT
059100            QXA-CHASSIS              =       AX-GAA-CHASSIS
059200       ON   EXCEPTION
059300       IF   DMSTATUS (NOTFOUND)
059400            GO                       TO      020-10-CHAS
059500       ELSE
059600            CALL     SYSTEM          DMTERMINATE.
059700
059800     FIND   QXACHASS                 AT
059900            QXA-CHASSIS              =       AX-GAA-CHASSIS
060000       ON   EXCEPTION
060100       IF   DMSTATUS (NOTFOUND)
060200            GO                       TO      020-10-CHAS
060300       ELSE
060400            CALL     SYSTEM          DMTERMINATE.
060500
060600     MOVE   QXA-TIPO-DECL            TO      AX-GAA-RET.
060700     MOVE   "Q"                      TO      AX-GAA-RET-DS.
060800     MOVE   QUEIXADS                 TO      AX-GAA-QUEIXA.
060900
061000 020-10-CHAS.
061100
061200     FIND   KEY OF   RECCHASS        AT
061300            REC-CHASSIS              =       AX-GAA-CHASSIS
061400       ON   EXCEPTION
061500       IF   DMSTATUS (NOTFOUND)
061600*
061700            GO                       TO      020-20-CHAS
061800       ELSE
061900            CALL     SYSTEM          DMTERMINATE.
062000
062100     FIND   RECCHASS                 AT
062200            REC-CHASSIS              =       AX-GAA-CHASSIS
062300       ON   EXCEPTION
062400       IF   DMSTATUS (NOTFOUND)
062500*
062600            GO                       TO      020-20-CHAS
062700       ELSE
062800            CALL     SYSTEM          DMTERMINATE.
062900
063000
063100     IF      AX-GAA-RET-DS           =       "Q"     AND
063200             ((QXA-DT-QUEIXA         >       REC-DT-RECUP) OR
063300              (QXA-DT-QUEIXA         =       REC-DT-RECUP AND
063400               QXA-HR-QUEIXA         >       REC-HR-RECUP))
063500             GO                      TO      020-20-CHAS
063600     ELSE
063700             NEXT    SENTENCE.
063800
063900
064000     MOVE    REC-TIPO-DECL           TO      AX-GAA-RET.
064100     MOVE    "R"                     TO      AX-GAA-RET-DS.
064200     MOVE    RECUPERADODS            TO      AX-GAA-QUEIXA.
064300
064400 020-20-CHAS.
064500
064600     FIND    KEY OF  ALECHASS        AT
064700             ALE-CHASSIS             =       AX-GAA-CHASSIS
064800       ON    EXCEPTION
064900       IF    DMSTATUS(NOTFOUND)
065000             MOVE    "S"             TO      CH-NOTFOUND
065100             GO                      TO      020-S-FIND-CHAS
065200       ELSE
065300             CALL    SYSTEM          DMTERMINATE.
065400
065500     FIND    ALECHASS                AT
065600             ALE-CHASSIS             =       AX-GAA-CHASSIS
065700       ON    EXCEPTION
065800       IF    DMSTATUS(NOTFOUND)
065900             MOVE    "S"             TO      CH-NOTFOUND
066000             GO                      TO      020-S-FIND-CHAS
066100       ELSE
066200             CALL    SYSTEM          DMTERMINATE.
066300
066400
066500     IF      AX-GAA-RET-DS           =       "Q"
066600       IF    QXA-DT-QUEIXA           >       ALE-DT-ALERTA   OR
066700             (QXA-DT-QUEIXA          =       ALE-DT-ALERTA AND
066800             QXA-HR-QUEIXA           >       ALE-HR-ALERTA)
066900             GO                      TO      020-S-FIND-CHAS
067000       ELSE
067100             NEXT    SENTENCE
067200     ELSE
067300     IF      AX-GAA-RET-DS           =       "R"
067400       IF    REC-DT-RECUP            >       ALE-DT-ALERTA   OR
067500             (REC-DT-RECUP           =       ALE-DT-ALERTA AND
067600             REC-HR-RECUP            >       ALE-HR-ALERTA)
067700             GO                      TO      020-S-FIND-CHAS
067800       ELSE
067900             NEXT    SENTENCE
068000     ELSE
068100             NEXT    SENTENCE.
068200
068300
068400     MOVE    88                      TO      AX-GAA-RET.
068500     MOVE    "A"                     TO      AX-GAA-RET-DS.
068600     MOVE    ALERTADS                TO      AX-GAA-QUEIXA.
068700
068800
068900 020-S-FIND-CHAS.
069000     EXIT.
069100/
069200******************************************************************
069300*    PESQUISA UF NO TABMUNBRDS                                   *
069400******************************************************************
069500
069600 030-E-FIND-TABMUN.
069700
069800
069900     FIND   TABMUNBRSE3              AT
070000            BR-COD-MUN               =       CH-GAA-MUNIC
070100       ON   EXCEPTION
070200       IF   DMSTATUS (NOTFOUND)
070300            MOVE     "9999"          TO      AX-RET-PESQ
070400            GO                       TO      030-S-FIND-TABMUN
070500       ELSE
070600            DISPLAY  "PC/GAA/L012/DB : FIND ERROR TTABELAS"
070700            CALL     SYSTEM          DMTERMINATE.
070800
070900     MOVE   BR-SIG-EST               TO      CH-GAA-UF.
071000
071100 030-S-FIND-TABMUN.
071200     EXIT.
071300/
071400******************************************************************
071500*    PESQUISA CAPITAL                                            *
071600******************************************************************
071700
071800 040-E-PESQ-TAB.
071900
072000     SET     IC1                     TO      1.
072100
072200     SEARCH  TAB-CAPITAL
072300       AT    END
072400             DISPLAY "PC/GAA/L012/DB - UF INVALIDA = " CH-GAA-UF
072500             DISPLAY "PC/GAA/L012/DB - MUNIC = " CH-GAA-MUNIC
072600             MOVE    99999           TO      AX-GAA-MUNIC
072700       WHEN  TAB-UF (IC1)            =       CH-GAA-UF
072800             MOVE    TAB-CAP (IC1)   TO      CH-GAA-MUNIC.
072900
073000 040-S-PESQ-TAB.
073100     EXIT.
