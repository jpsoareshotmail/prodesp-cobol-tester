012300******************************************************************
012400*    PARAMETRO PARA VERIFICACAO DE BLOQUEIO NO DBFURTO           *
012500******************************************************************
012600
012700 01          AX-LIB-GAAL012.
012800
012900     05      AX-GAA-PLACA            PIC X(005).
013000
013100     05      AX-GAA-MUNIC            PIC 9(005).
013200
013300     05      AX-GAA-CHASSIS          PIC X(022).
013400
013500     05      FILLER                  PIC 9(001).
013600     05      AX-GAA-BLOQ             PIC 9(001).
013700       88    AX-PAR                  VALUE  0 2 4 6 8.
013800
013900     05      AX-GAA-PLAMERC          PIC X(010).
014000
014100*
014200*====> AX-PAR - DEVIDO A REFORMULACAO DO SISTEMA DE BLOQUEIO
014300*
014400*====> AX-GAA-RET     =  0  -> NENHUM REGISTRO FOI ENCONTRADO
014500*                        1  -> ROUBO
014600*                        2  -> FURTO
014700*                        3  -> APROPRIACAO INDEBITA
014800*                        4  -> ESTELIONATO
014900*                        5  -> VEICULO E PESSOA DESAPARECIDA
015000*                        6  -> EXTORSAO
015100*                        7  -> CONCUSSAO
015200*                        8  -> PECULATO
015300*                        9  -> OUTROS CRIMES
015400*                        88 -> VEICULO COM ALERTA DE FURTO/ROUBO
015500
015600*====> AX-GAA-RET-BLQ =  0  -> NADA CONSTA
015700*                        1  -> SUBJUDICE
015800*
015900*====> AX-GAA-RET-DS  = "Q" -> QUEIXADS
016000*                       "R" -> RECUPERADODS
016100*                       "A" -> ALERTADS
016200
016300*====> AX-GAA-RET-NRO = RETORNA O NUMERO DO BO
016400
016500*====> AX-GAA-RET-UF  = RETORNA A UF DO BO
016600
016700*====> AX-GAA-RET-DEL = RETORNA A DELEGACIA DO BO
016800
016900*====> AX-GAA-RET-DT  = RETORNA A DATA
017000
017100*====> AX-GAA-RET-HR  = RETORNA A HORA
017200
017300
017400 01          AX-GAA-RETL012.
017500
017600     05      AX-RET-PESQ.
017700       10    AX-GAA-RET              PIC 9(002).
017800       10    AX-GAA-RET-BLQ          PIC 9(001).
017900       10    AX-GAA-RET-DS           PIC X(001).
018000* UNISYS Y2K MANUAL CHANGE
018100*    05      AX-GAA-QUEIXA           PIC X(250).
018200     05      AX-GAA-QUEIXA           PIC X(258).
018300* UNISYS Y2K END
018400*
018500*====> AX-RET-PESQ :
018600*
018700*      000   -> NADA CONSTA
018800*      001   -> SUBJUDICE
018900*      010Q  -> ROUBADO
019000*      011Q  -> ROUBADO E SUBJUDICE
019100*      010R  -> ROUBADO / RECUPERADO
019200*      011R  -> ROUBADO / RECUPERADO E SUBJUDICE
019300*      020Q  -> FURTADO
019400*      021Q  -> FURTADO E SUBJUDICE
019500*      020R  -> FURTADO / RECUPERADO
019600*      021R  -> FURTADO / RECUPERADO E SUBJUDICE
019700*      030Q  -> APROPRIACAO INDEBITA
019800*      031Q  -> APROPRIACAO INDEBITA E SUBJUDICE
019900*      030R  -> APROPRIACAO INDEBITA / RECUPERADO
020000*      031R  -> APROPRIACAO INDEBITA / RECUPERADO E SUBJUDICE
020100*      040Q  -> ESTELIONATO
020200*      041Q  -> ESTELIONATO E SUBJUDICE
020300*      040R  -> ESTELIONATO / RECUPERADO
020400*      041R  -> ESTELIONATO / RECUPERADO E SUBJUDICE
020500*      050Q  -> VEIC. E PESSOA DESAPARECIDA
020600*      051Q  -> VEIC. E PESSOA DESAPARECIDA E SUBJUDICE
020700*      050R  -> VEIC. E PESSOA DESAPARECIDA / RECUPERADO
020800*      051R  -> VEIC. E PESSOA DESAPARECIDA / RECUPERADO SUBJUDICE
020900*      060Q  -> EXTORSAO
021000*      060R  -> EXTORSAO / RECUPERADO
021100*      070Q  -> CONCUSSAO
021200*      070R  -> CONCUSSAO / RECUPERADO
021300*      080Q  -> PECULATO
021400*      080R  -> PECULATO / RECUPERADO
021500*      090Q  -> OUTROS CRIMES
021600*      090R  -> OUTROS CRIMES  / RECUPERADO
021700*      880A  -> VEIC. COM ALERTA DE FURTO/ROUBO
021800*      9999  -> MUNICIPIO INVALIDO
021900/
