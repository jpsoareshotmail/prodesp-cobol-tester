029700/*****************************************************************
029800*        ROTINA  DE  TRATAMENTO  DAS  TRANSACOES  DO  PROGRAMA   *
029900******************************************************************
030000
030100 010-E-PROCESSA.
030200
030300     MOVE    SPACES                  TO          AREA-IN
030400                                                 AREA-OUT.
030500
030600     MOVE    0                       TO          CH-NOTF
030700                                                 IA1.
030800
030900
031000     RECEIVE COMS-IN MESSAGE         INTO        AREA-IN.
031100
031200
031300     IF      IN-STATUS               =           0   OR  80  OR
031400                                                 89  OR  90  OR
031500                                                 91  OR  92  OR
031600                                                 93  OR  94  OR
031700                                                 97
031800             NEXT    SENTENCE
031900     ELSE
032000     IF      IN-STATUS               =           99
032100             GO                      TO          010-S-PROCESSA
032200     ELSE
032300             PERFORM 150-E-ERRO-IN   THRU        150-S-ERRO-IN
032400             GO                      TO          010-S-PROCESSA.
032500
032550     IF      IN-CODE                 =           "V435"
032600             PERFORM 020-E-CONSISTE  THRU        020-S-CONSISTE
032620     ELSE
032640             MOVE    239             TO          IA1.
032700
032800     PERFORM 100-E-ENV-ERRO          THRU        100-S-ENV-ERRO.
032900
033000 010-S-PROCESSA.     EXIT.
033100
033200/*****************************************************************
033300*                   ROTINA DE CONSISTENCIA                       *
033400******************************************************************
033500 020-E-CONSISTE.
033600
033700     ACCEPT  WS-DATE                 FROM        DATE.
033800
033900     MOVE    WS-DATE-DIA             TO          WS-MAQDIA
034000                                                 WS-DIAAMD.
034100     MOVE    WS-DATE-MES             TO          WS-MAQMES
034200                                                 WS-MESAMD.
034300     MOVE    WS-DATE-ANO             TO          WS-MAQANO
034400
034500
034600
034700     IF      IN-PLACA                EQUAL       SPACES OR ZEROS
034800             MOVE    01              TO          IA1
034900             GO                      TO          020-1-PROCESSO
035000     ELSE
035100             NEXT    SENTENCE.
035200
035300*     MOVE    IN-PLACA                TO          WS-PLACA.
035400
035500*     IF      WS-LETRA                NOT         ALPHABETIC  OR
035600*             WS-NUMERO               NOT         NUMERIC
035700*             MOVE    01              TO          IA1
035800*             GO                      TO          020-1-PROCESSO
035900*     ELSE
036000*             NEXT    SENTENCE.
036100
036200*     MOVE    WS-LETRA                TO          AX-LETRA
036300*     MOVE    WS-NUM1-R               TO          AX-NUMERO1.
036400*     MOVE    WS-NUM2-R               TO          AX-NUMERO2.
036500
036600     IF      IN-CHASSI               EQUAL       SPACES OR ZEROS
036700             MOVE    02              TO          IA1
036800             GO                      TO          020-1-PROCESSO
036900     ELSE
037000             NEXT    SENTENCE.
037100
037200
037300     IF      IN-CNPJX                EQUAL       SPACES OR ZEROS
037400             MOVE    03              TO          IA1
037500             GO                      TO          020-1-PROCESSO
037600     ELSE
037700             NEXT    SENTENCE.
037800
037820     MOVE    ZERO                    TO          AX-TAX-LENGTH.
037840
037860     MOVE    SPACES                  TO          AX-TAXA.
037880
037900
038000     IF      IN-AUTENTICACAO         EQUAL       SPACES         OR
038010                                                 LOW-VALUES     OR
038020                                                 ZEROS
038100             MOVE    04              TO          IA1
038200             GO                      TO          020-1-PROCESSO
038300     ELSE
038400             UNSTRING  IN-AUTENTICACAO
038405             DELIMITED BY  " " OR LOW-VALUES
038410             INTO      AX-AUT-DIG-DUT, COUNT IN  AX-TAX-LENGTH
038415
038420       IF    AX-TAX-LENGTH       NOT =           64 AND 18
038425             MOVE    04              TO          IA1
038430             GO                      TO          020-1-PROCESSO
038435       ELSE
038440         IF  AX-TAX-LENGTH           =           18  OR
038445            (AX-TAX-LENGTH           =           64  AND
038450             IN-AUT-DIG-4POS         IS          NUMERIC)
038455          IF AX-TAX-LENGTH           =           18
038460             MOVE    IN-TAXA         TO          AX-TAXA
038465          ELSE
038470             MOVE    18              TO          AX-TAX-LENGTH
038475             MOVE    IN-AX-COD-BANCO TO          IN-AUT-CODBCO
038480             MOVE    IN-AX-DT-CONTB  TO          IN-AUT-DTCONT
038485             MOVE    IN-AX-NSU-PROD  TO          IN-AUT-NSUPROD
038490         ELSE
038495             MOVE    04              TO          IA1
038498             GO                      TO          020-1-PROCESSO.
038500
038510     IF      IN-DESP-SSP             IS          NUMERIC  AND
038520             IN-DESP-SSP             >           ZEROS
038530             NEXT    SENTENCE
038540     ELSE
038550             MOVE    75              TO          IA1
038560             GO                      TO          020-1-PROCESSO.
038570
038600     PERFORM 030-E-NOVAPLACA         THRU        030-S-NOVAPLACA.
038700
038800     IF      CH-NOTF                 EQUAL       1
038900             MOVE    06              TO          IA1
039000             GO                      TO          020-1-PROCESSO
039100     ELSE
039200     IF      NPL-CHASSI          NOT EQUAL       IN-CHASSI
039300             MOVE    07              TO          IA1
039400             GO                      TO          020-1-PROCESSO
039500     ELSE
039600     IF      NPL-CPF-CGC         NOT EQUAL       IN-CNPJ
039700             MOVE    08              TO          IA1
039800             GO                      TO          020-1-PROCESSO
039900     ELSE
040000     IF      NPL-SITUACAO        NOT EQUAL       4
040100             MOVE    11              TO          IA1
040200             GO                      TO          020-1-PROCESSO
040300     ELSE
040400             NEXT    SENTENCE.
040500
043010
043015     IF      AX-TAX-LENGTH           =           18
043020             PERFORM 220-E-TAXAS     THRU        220-S-TAXAS
043025
043030        IF   CH-NOTFOUND-TAX         =           "N"
043043         IF  TAX-COD-PAG             NOT =       92
043045             MOVE    09              TO          IA1
043050             GO                      TO          020-1-PROCESSO
043055         ELSE
043060         IF  TAX-SITUACAO            NOT =       ZEROS
043065             MOVE    12              TO          IA1
043070             GO                      TO          020-1-PROCESSO
043075         ELSE
043080         IF  TAX-CPF-CGC             =           IN-CNPJ
043085             NEXT    SENTENCE
043090         ELSE
043095             MOVE    10              TO          IA1
043100             GO                      TO          020-1-PROCESSO
043105        ELSE
043110             MOVE    05              TO          IA1
043115             GO                      TO          020-1-PROCESSO.
043120
043125
043130     PERFORM 080-E-ALTERA            THRU        080-S-ALTERA.
043135
043140     IF      AX-TAX-LENGTH           =           18  AND
043145             CH-NOTFOUND-TAX         =           "N"
043150             PERFORM 085-E-GRAVA-TAXASDS
043155                     THRU            085-S-GRAVA-TAXASDS.
043160
043162 020-1-PROCESSO.
043165
043170     FREE    TAXASDS.
043180     FREE    NOVAPLACDS.
043185
043190
043300 020-S-CONSISTE.     EXIT.
043400
