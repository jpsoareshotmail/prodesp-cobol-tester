059200 100-E-ENV-ERRO.
059300
059400     MOVE    0                       TO          OUT-STATUS.
059500     MOVE    1                       TO          OUT-COUNT.
059600     MOVE    122                     TO          OUT-TEXT-LENGTH.
059700
059800     MOVE    IN-HEADER               TO          OUT-HEADER.
059900     MOVE    IA1                     TO          OUT-COD.
060000     MOVE    WS-AGENDA-DESG          TO          OUT-AGENDA.
060100     MOVE    IN-STATION              TO          OUT-DESTINATION.
060200
060300     SEND    COMS-OUT                FROM        AREA-OUT.
060400
060500
060600 100-S-ENV-ERRO.     EXIT.
060700
060800
060900/*****************************************************************
061000*       ROTINA DE ERRO DE LEITURA                                *
061100******************************************************************
061200
061300 150-E-ERRO-IN.
061400
061500     DISPLAY "GEV/T435 - PROBLEMAS NO COMS-IN".
061600     DISPLAY "FUNCTIONINDEX = "     IN-FUNCTION-INDEX.
061700     IF      IN-STATUS               =           20  OR  100   OR
061800                                                 101 OR  102
061900             DISPLAY "PROBLEMAS COM A ESTACAO"
062000     ELSE
062100     IF      IN-STATUS               =           94  OR  95    OR
062200                                                 97
062300             DISPLAY "DESTINO INVALIDO"
062400     ELSE
062500             DISPLAY " STATUSVALUE  = "          IN-STATUS.
062600
062700
062800     MOVE    1                       TO          OUT-COUNT.
062900     MOVE    0                       TO          OUT-DESTINATION.
063000     MOVE    0                       TO          OUT-STATUS.
063100     MOVE    122                     TO          OUT-TEXT-LENGTH.
063200
063300     SEND    COMS-OUT                FROM        AREA-OUT.
063400
063500     IF      OUT-STATUS              NOT =        0  AND  92
063600             DISPLAY "ERRO NO ENVIO DA MENSAGEM".
063700
063800
063900     MOVE    99                      TO          IN-STATUS.
064000
064100
064200 150-S-ERRO-IN.      EXIT.
064300
064400
064500******************************************************************
064600*    CANCELAMENTO DO PROGRAMA POR ERRO DE DB                     *
064700******************************************************************
064800*
064900 200-E-ERRODB.
065000
065100
065200
065300     DISPLAY "* *  ERRO  DE  DMS-II  * *"
065400     IF      DMSTATUS(NOTFOUND)      DISPLAY "NOTFOUND"      ELSE
065500     IF      DMSTATUS(DUPLICATES)    DISPLAY "DUPLICATES"    ELSE
065600     IF      DMSTATUS(DEADLOCK)      DISPLAY "DEADLOCK"      ELSE
065700     IF      DMSTATUS(KEYCHANGED)    DISPLAY "KEYCHANGED"    ELSE
065800     IF      DMSTATUS(DATAERROR)     DISPLAY "DATAERROR"     ELSE
065900     IF      DMSTATUS(NOTLOCKED)     DISPLAY "NOTLOCKED"     ELSE
066000     IF      DMSTATUS(SYSTEMERROR)   DISPLAY "SYSTEMERROR"   ELSE
066100     IF      DMSTATUS(IOERROR)       DISPLAY "IOERROR"       ELSE
066200     IF      DMSTATUS(LIMITERROR)    DISPLAY "LIMITERROR"    ELSE
066300     IF      DMSTATUS(OPENERROR)     DISPLAY "OPENERROR"     ELSE
066400     IF      DMSTATUS(CLOSEERROR)    DISPLAY "CLOSEERROR"    ELSE
066500     IF      DMSTATUS(NORECORD)      DISPLAY "NORECORD"      ELSE
066600     IF      DMSTATUS(INUSE)         DISPLAY "INUSE"         ELSE
066700     IF      DMSTATUS(AUDITERROR)    DISPLAY "AUDITERROR"    ELSE
066800     IF      DMSTATUS(ABORT)         DISPLAY "ABORT"         ELSE
066900     DISPLAY "ERRO  NAO  IDENTIFICADO  NAS  CONDICOES  D.M.S. ".
067000
067100
067200     DISPLAY "STRUCTURE - "  DMSTATUS(DMSTRUCTURE).
067300     DISPLAY "TYPE      - "  DMSTATUS(DMERRORTYPE).
067400     DISPLAY "PROG.  PC/GEV/T435/DB".
067500
067600
067700 200-S-ERRODB.       EXIT.
067800
070900
071000/
071100******************************************************************
071200*        VERIFICA SE TEM TAXA                                    *
071300******************************************************************
071400*
071500 220-E-TAXAS.
071600
071700     MOVE    "N"                     TO      CH-NOTFOUND-TAX.
071800
071900     LOCK    LAST   TAXBCDTPSE1      AT
072000             TAX-COD-BANCO           =       IN-AUT-CODBCO     AND
072100             TAX-NSU-PROD            =       IN-AUT-NSUPROD    AND
072200             TAX-DT-CONTB            =       IN-AUT-DTCONT
072300       ON    EXCEPTION
072400       IF    DMSTATUS (NOTFOUND)
072500             MOVE    "S"             TO      CH-NOTFOUND-TAX
072600
072700       ELSE
072800             DISPLAY "PC/GEV/T435/DB: FIND ERROR TAXBCDTPSE1"
072900             PERFORM 200-E-ERRODB    THRU    200-S-ERRODB
073000             CALL    SYSTEM          DMTERMINATE.
073100
073200
073300 220-S-TAXAS.
073400     EXIT.
073500
073600
