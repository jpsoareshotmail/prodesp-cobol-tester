026000
026100 MONITORA    SECTION.
026200 000-E-MONITORA.
026300
026400     MOVE    ATTRIBUTE NAME OF ATTRIBUTE EXCEPTIONTASK
026500                            OF ATTRIBUTE EXCEPTIONTASK OF MYSELF
026600                            TO LINKTOCOMS.
026700
026800     CHANGE  ATTRIBUTE TITLE OF "DCILIBRARY" TO LINKTOCOMS.
026900
027000     ENABLE  INPUT  COMS-IN          KEY         "ONLINE"
027100
027200     CALL    "GET_DESIGNATOR_USING_NAME IN DCILIBRARY"
027300                                    USING        WS-AGENDA-OUT,
027400                                    VALUE        AGENDA,
027500                                                 WS-AGENDA-DESG
027600                                    GIVING       WS-CALL-ERROR.
027700
027800     OPEN    UPDATE      DB01
027900       ON    EXCEPTION
028000             DISPLAY "GEV/T435 - ERRO OPEN TDBDETRAN"
028100             CALL    SYSTEM  DMTERMINATE.
028110
028120
028130     OPEN    UPDATE      DB02
028140       ON    EXCEPTION
028150             DISPLAY "GEV/T435 - ERRO OPEN TDBTAXAS"
028160             CALL    SYSTEM  DMTERMINATE.
028170
028300
028400     PERFORM 010-E-PROCESSA          THRU        010-S-PROCESSA
028500             UNTIL   IN-STATUS       EQUAL       99.
028600
028700
028800     CLOSE   DB01
028900       ON    EXCEPTION
029000             DISPLAY "GEV/T435 - ERRO CLOSE TDBDETRAN"
029100             CALL    SYSTEM  DMTERMINATE.
029200
029210
029220     CLOSE   DB02
029230       ON    EXCEPTION
029240             DISPLAY "GEV/T435 - ERRO CLOSE TDBTAXAS"
029250             CALL    SYSTEM  DMTERMINATE.
029300
029400
029500 000-S-MONITORA.     STOP RUN.
