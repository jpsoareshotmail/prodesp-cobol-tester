816700             MOVE    4                      TO     L160-SOLIC
816800
816900             CALL   "PROCEDUREDIVISION  OF  PC/GAA/L160"
817000                                            USING  L160-PARAM-E
817100                                            L160-PARAM-S
817200
817300             IF     L160-RETORNO    NOT  =   ZEROS
817400                    MOVE   L160-RETORNO      TO     OBS-CPF-EXCL
817500                    MOVE   "E"               TO     OBS-SITUACAO
817600             ELSE
817700
817800             IF     L160-RET-BIN      =       200    OR   201
817900                    MOVE      200     TO      OBS-RETBIN
818000                    MOVE      "F"     TO      OBS-SITUACAO
818100                    ACCEPT    OBS-DT-EXCLUSAO FROM DATE YYYYMMDD
818200                    ACCEPT    OBS-HR-EXCLUSAO FROM TIME
818300
818400             ELSE
818500             IF      L160-RET-BIN      =        422       AND
818600                     L160-RETMSG       = "RESTRICAO JA FINALIZADA"
818700                     MOVE     200              TO  OBS-RETBIN
818800                     ACCEPT    OBS-DT-EXCLUSAO FROM DATE YYYYMMDD
818900                     ACCEPT    OBS-HR-EXCLUSAO FROM TIME
819000                     MOVE     "F"       TO      OBS-SITUACAO
819100
819200             ELSE
819300
819400                     MOVE      ZEROS          TO     OBS-RETBIN
819500                     MOVE      SPACES         TO     OBS-SITUACAO
819600
819700     ELSE
819800              MOVE       "F"       TO     OBS-SITUACAO.
819900
820000     MOVE      USUARIO            TO     OBS-USU-EXCL
820100     MOVE     "E"                 TO     OBS-MANUT.
820200
820300     STORE   OBSERVCRLVDS
820400           ON  EXCEPTION
820500               DISPLAY "PC/GAA/T080/DB - STORE ERROR OBSERVCRLVDS"
820600               CALL    SYSTEM  DMTERMINATE.
820700
