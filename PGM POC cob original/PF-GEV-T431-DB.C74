057300******************************************************************
057400*                P R O C E S S A M E N T O                       *
057500******************************************************************
057600*
057700 020-E-PROCESSA.
057800
057900
058000
058100     MOVE    SPACES                  TO      AREA-IN
058200                                             AREA-OUT.
058300
058400     RECEIVE COMS-IN MESSAGE         INTO    AREA-IN.
058500
058600     IF      COMS-IN-STATUS          =       00 OR 89 OR 92 OR
058700                                             93 OR 97
058800             NEXT    SENTENCE
058900     ELSE
059000     IF      COMS-IN-STATUS          =       99
059100             GO                      TO      020-S-PROCESSA
059200     ELSE
059300             PERFORM 130-E-ERROCOMS  THRU    130-S-ERROCOMS
059400             GO                      TO      020-S-PROCESSA.
059500
059600
059700     MOVE    COMS-IN-USERCODE        TO      USER-DESG.
059800
059900     CALL    "GET_NAME_USING_DESIGNATOR  OF  DCILIBRARY"
060000                                     USING   USER-DESG
060100                                             USER-NAME
060200                                     GIVING  USER-FLAG.
060300
060400
060500
060600
060700
060800
060900
061000     IF      IN-CODE                 =       "V431"
061100             PERFORM 030-E-V431      THRU    030-S-V431
061200     ELSE
061300             MOVE    239             TO      IA1.
061400
061500
061600     MOVE    142                     TO      AX-LENGTH.
061700
061800     PERFORM 120-E-MSGOUT            THRU    120-S-MSGOUT.
061900
062000
062100
062200
062300 020-S-PROCESSA.
062400     EXIT.
062500
