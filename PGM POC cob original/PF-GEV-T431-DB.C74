073300             MOVE  AX-CNPJ-DIG       TO      AX-LIB-CNPJ-DIG
073400             MOVE  SPACES            TO      AX-LIB-DC-CONS
073500             MOVE  12                TO      AX-LIB-DC-TAM
073600             CALL  "DIGITCGC         OF      PC/LIB/DIGITCHECK"
073700                                     USING   AX-LIB-DC-CNPJ
073800                                             AX-LIB-DC-PARM.
073900             IF    AX-LIB-DC-CONS    NOT =   1
074000                   MOVE  001         TO      IA1
074100                   GO                TO      040-S-VERIF-IN.
074200
