050000*
050100******************************************************************
050200*        ROTINA    MONITORA    DO    PROGRAMA                    *
050300******************************************************************
050400*
050500 000-MONITORA    SECTION.
050600
050700 000-E-MONITORA.
050800
050900
051000
051100     PERFORM 010-E-INICIO            THRU    010-S-INICIO.
051200
051300
051400     PERFORM 020-E-PROCESSA          THRU    020-S-PROCESSA
051500             UNTIL   COMS-IN-STATUS  =       99.
051600
051700
051800     PERFORM 150-E-FINAL             THRU    150-S-FINAL.
051900
052000
052100
052200 000-S-MONITORA.
052300     STOP    RUN.
052400
052500/
052600******************************************************************
052700*                   INICIALIZACAO                                *
052800******************************************************************
052900*
053000 010-E-INICIO.
053100
053200
053300
053400     MOVE    ATTRIBUTE NAME OF ATTRIBUTE EXCEPTIONTASK
053500                            OF ATTRIBUTE EXCEPTIONTASK OF MYSELF
053600                            TO LINKTOCOMS.
053700
053800
053900     CHANGE  ATTRIBUTE TITLE OF "DCILIBRARY" TO LINKTOCOMS.
054000
054100
054200     ENABLE  INPUT   COMS-IN         KEY     "ONLINE"
054300
054400     CALL    "GET_DESIGNATOR_USING_NAME  IN  DCILIBRARY"
054500                                     USING   AX-AGENDA-OUT,
054600                                     VALUE   AGENDA,
054700                                             AX-AGENDA-DESG
054800                                     GIVING  AX-CALL-ERROR.
054900
055000
055100
055200
055300     OPEN    UPDATE     DB01
055400       ON    EXCEPTION
055500             DISPLAY "PC/GEV/T431/DB : OPEN ERROR TDBDETRAN"
055600             PERFORM 140-E-ERRODB    THRU    140-S-ERRODB
055700             CALL    SYSTEM          DMTERMINATE.
055800
055900
056000     OPEN    INQUIRY    DB02
056100       ON    EXCEPTION
056200             DISPLAY "PC/GEV/T431/DB : OPEN ERROR TDBGEVER"
056300             PERFORM 140-E-ERRODB    THRU    140-S-ERRODB
056400             CALL    SYSTEM          DMTERMINATE.
056500
056600
056700
056800
056900 010-S-INICIO.
057000     EXIT.
057100
